-- ========== 移速效果主循环 ==========
local player = game:GetService("Players").LocalPlayer
local runService = game:GetService("RunService")
local userInputService = game:GetService("UserInputService")
local currentSpeed = 0

local function setupSpeedEffect()
    runService.RenderStepped:Connect(function()
        if not getgenv().ObsidianSpeed.Enabled then return end
        
        local character = player.Character
        if not character then return end
        
        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then return end
        
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        -- 获取移动方向
        local moveDir = humanoid.MoveDirection
        
        if moveDir.Magnitude > 0.1 then
            local targetSpeed = getgenv().ObsidianSpeed.Speed
            local mode = getgenv().ObsidianSpeed.Mode
            
            -- 根据模式计算每帧移动距离
            local frameMove = 0
            
            if mode == "Smooth" then
                frameMove = math.min(targetSpeed / 30, 3)
            elseif mode == "Balanced" then
                frameMove = math.min(targetSpeed / 20, 5)
            elseif mode == "Fast" then
                frameMove = math.min(targetSpeed / 10, 10)
            elseif mode == "Teleport" then
                frameMove = targetSpeed / 8
            elseif mode == "BodyVelocity" then
                -- 物理移动模式
                local bv = rootPart:FindFirstChild("ObsidianSpeedBV")
                if not bv then
                    bv = Instance.new("BodyVelocity")
                    bv.Name = "ObsidianSpeedBV"
                    bv.MaxForce = Vector3.new(4000, 0, 4000)
                    bv.Parent = rootPart
                end
                bv.Velocity = moveDir * targetSpeed * 2
                return
            end
            
            -- 平滑过渡
            if getgenv().ObsidianSpeed.Smoothing then
                currentSpeed = currentSpeed + (targetSpeed - currentSpeed) * 0.1
                frameMove = currentSpeed / 30
            end
            
            -- 应用移动
            local moveAmount = moveDir * frameMove
            rootPart.CFrame = rootPart.CFrame + moveAmount
        else
            -- 移除物理效果
            if rootPart then
                local bv = rootPart:FindFirstChild("ObsidianSpeedBV")
                if bv then bv:Destroy() end
            end
            currentSpeed = 0
        end
    end)
end

-- 启动移速效果
setupSpeedEffect()

-- 键盘快捷键
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- F8 开关效果
    if input.KeyCode == Enum.KeyCode.F8 then
        getgenv().ObsidianSpeed.Enabled = not getgenv().ObsidianSpeed.Enabled
        if getgenv().ObsidianSpeed.ShowNotifications then
            Library:Notify("速度控制", getgenv().ObsidianSpeed.Enabled and "✅ 已开启" or "❌ 已关闭", 1.5)
        end
    end
    
    -- 数字键快速设置
    if input.KeyCode == Enum.KeyCode.One then
        getgenv().ObsidianSpeed.Speed = 16
        CurrentSpeedLabel:Set("当前速度: 16 单位")
    elseif input.KeyCode == Enum.KeyCode.Two then
        getgenv().ObsidianSpeed.Speed = 30
        CurrentSpeedLabel:Set("当前速度: 30 单位")
    elseif input.KeyCode == Enum.KeyCode.Three then
        getgenv().ObsidianSpeed.Speed = 50
        CurrentSpeedLabel:Set("当前速度: 50 单位")
    elseif input.KeyCode == Enum.KeyCode.Four then
        getgenv().ObsidianSpeed.Speed = 100
        CurrentSpeedLabel:Set("当前速度: 100 单位")
    end
end)

