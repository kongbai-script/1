local originalSpeeds = {}

local function createKeycardESP()
    if not getgenv().KeycardESP.Enabled then return end
    
    local map = workspace:FindFirstChild("Map")
    if not map then return end
    
    for _, obj in ipairs(map:GetDescendants()) do
        if obj.Name == "Keycard" then
            local tag = obj:FindFirstChild("KeycardTag")
            if not tag then
                local billboard = Instance.new("BillboardGui")
                billboard.Name = "KeycardTag"
                billboard.Parent = obj
                billboard.Size = UDim2.new(0, 100, 0, 30)
                billboard.AlwaysOnTop = true
                billboard.StudsOffset = Vector3.new(0, 1, 0)
                
                local text = Instance.new("TextLabel")
                text.Parent = billboard
                text.Size = UDim2.new(1, 0, 1, 0)
                text.BackgroundTransparency = 1
                text.TextColor3 = Color3.fromRGB(255, 255, 0)
                text.TextScaled = true
                text.Text = "钥匙卡"
                text.Font = Enum.Font.GothamBold
                text.TextStrokeTransparency = 0.3
                text.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            end
        end
    end
end

local function destroyKeycardESP()
    local map = workspace:FindFirstChild("Map")
    if map then
        for _, obj in ipairs(map:GetDescendants()) do
            if obj.Name == "Keycard" then
                local tag = obj:FindFirstChild("KeycardTag")
                if tag then tag:Destroy() end
            end
        end
    end
end

local function createItemESP()
    if not getgenv().ItemESP.Enabled then return end
    
    local map = workspace:FindFirstChild("Map")
    if not map then return end
    
    for _, item in ipairs(map:GetChildren()) do
        if item:IsA("Tool") then
            local tag = item:FindFirstChild("ItemTag")
            if not tag then
                local billboard = Instance.new("BillboardGui")
                billboard.Name = "ItemTag"
                billboard.Parent = item
                billboard.Size = UDim2.new(0, 120, 0, 30)
                billboard.AlwaysOnTop = true
                billboard.StudsOffset = Vector3.new(0, 2, 0)
                
                local text = Instance.new("TextLabel")
                text.Parent = billboard
                text.Size = UDim2.new(1, 0, 1, 0)
                text.BackgroundTransparency = 1
                text.TextColor3 = Color3.fromRGB(0, 255, 0)
                text.TextScaled = true
                text.Text = item.Name
                text.Font = Enum.Font.GothamBold
                text.TextStrokeTransparency = 0.3
                text.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            end
        end
    end
end

local function destroyItemESP()
    local map = workspace:FindFirstChild("Map")
    if map then
        for _, item in ipairs(map:GetChildren()) do
            if item:IsA("Tool") then
                local tag = item:FindFirstChild("ItemTag")
                if tag then tag:Destroy() end
            end
        end
    end
end

local function getAllEnemyHumanoids()
    local humanoids = {}
    local enemyFolder = workspace:FindFirstChild("Enemy")
    
    if enemyFolder then
        for _, descendant in ipairs(enemyFolder:GetDescendants()) do
            if descendant:IsA("Humanoid") then
                table.insert(humanoids, descendant)
            end
        end
    end
    return humanoids
end

local function lockEnemies()
    if not getgenv().EnemyLock.Enabled then return end
    
    local humanoids = getAllEnemyHumanoids()
    for _, humanoid in ipairs(humanoids) do
        if humanoid.WalkSpeed ~= 0 then
            if not originalSpeeds[humanoid] then
                originalSpeeds[humanoid] = humanoid.WalkSpeed
            end
            humanoid.WalkSpeed = 0
        end
    end
end

local function unlockEnemies()
    local humanoids = getAllEnemyHumanoids()
    for _, humanoid in ipairs(humanoids) do
        local original = originalSpeeds[humanoid]
        if original then
            humanoid.WalkSpeed = original
        else
            if humanoid.WalkSpeed == 0 then
                humanoid.WalkSpeed = 16
            end
        end
    end
    originalSpeeds = {}
end

local function setupEnemyListener()
    local enemyFolder = workspace:FindFirstChild("Enemy")
    if enemyFolder then
        enemyFolder.DescendantAdded:Connect(function(descendant)
            task.wait(0.1)
            if descendant:IsA("Humanoid") and getgenv().EnemyLock.Enabled then
                if not originalSpeeds[descendant] then
                    originalSpeeds[descendant] = descendant.WalkSpeed
                end
                descendant.WalkSpeed = 0
            end
        end)
    end
end

local liquidConnection = nil
local function startLiquidDelete()
    if liquidConnection then liquidConnection:Disconnect() end
    liquidConnection = runService.RenderStepped:Connect(function()
        if not getgenv().LiquidDelete.Enabled then return end
        
        local map = workspace:FindFirstChild("Map")
        if not map then return end
        
        for _, child in ipairs(map:GetChildren()) do
            local hazard = child:FindFirstChild("Hazard")
            if hazard then
                for _, obj in ipairs(hazard:GetChildren()) do
                    pcall(function() obj:Destroy() end)
                end
            end
        end
    end)
end

local function stopLiquidDelete()
    if liquidConnection then
        liquidConnection:Disconnect()
        liquidConnection = nil
    end
end

