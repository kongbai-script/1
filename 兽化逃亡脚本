function Sound()
    local sound = Instance.new("Sound", game:GetService("SoundService"))
    sound.Volume = 2.5
    sound.SoundId = "rbxassetid://" .. notifysound
    sound.Playing = PlayingSound and true or false
    game:GetService("Debris"):AddItem(sound, 2)
end

