local enabled = false
local dragging = false
local dragStartPos = nil
local frameStartPos = nil

local function getAllEnemyHumanoids()
    local humanoids = {}
    local enemyFolder = workspace:FindFirstChild("Enemy")
    
    if enemyFolder then
        for _, descendant in ipairs(enemyFolder:GetDescendants()) do
            if descendant:IsA("Humanoid") then
                table.insert(humanoids, descendant)
            end
        end
    end
    return humanoids
end

local function lockEnemies()
    local humanoids = getAllEnemyHumanoids()
    for _, humanoid in ipairs(humanoids) do
        if humanoid.WalkSpeed ~= 0 then
            humanoid.WalkSpeed = 0
        end
    end
end

local function unlockEnemies()
    local humanoids = getAllEnemyHumanoids()
    for _, humanoid in ipairs(humanoids) do
        if humanoid.WalkSpeed ~= 16 then
            humanoid.WalkSpeed = 16
        end
    end
end

local function updateUI()
    if enabled then
        toggleButton.Text = "关闭锁定"
        toggleButton.BackgroundColor3 = Color3.fromRGB(220, 60, 50)
        statusLabel.Text = "已锁定 (速度=0)"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        titleLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    else
        toggleButton.Text = "开启锁定"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        statusLabel.Text = "未锁定 (速度=16)"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        titleLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    end
end

local function toggleLock()
    enabled = not enabled
    
    if enabled then
        lockEnemies()
    else
        unlockEnemies()
    end
    
    updateUI()
end

toggleButton.MouseButton1Click:Connect(toggleLock)

local function startDrag(input)
    dragging = true
    dragStartPos = input.Position
    frameStartPos = mainFrame.Position
end

local function onDrag(input)
    if dragging then
        local delta = input.Position - dragStartPos
        local newX = frameStartPos.X.Offset + delta.X
        local newY = frameStartPos.Y.Offset + delta.Y
        
        newX = math.clamp(newX, 0, screenGui.AbsoluteSize.X - mainFrame.AbsoluteSize.X)
        newY = math.clamp(newY, 0, screenGui.AbsoluteSize.Y - mainFrame.AbsoluteSize.Y)
        
        mainFrame.Position = UDim2.new(0, newX, 0, newY)
    end
end

local function endDrag()
    dragging = false
end

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        startDrag(input)
    end
end)

userInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch then
        onDrag(input)
    end
end)

userInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        endDrag()
    end
end)

local enemyFolder = workspace:FindFirstChild("Enemy")
if enemyFolder then
    enemyFolder.DescendantAdded:Connect(function(descendant)
        task.wait(0.1)
        if descendant:IsA("Humanoid") then
            if enabled then
                descendant.WalkSpeed = 0
            else
                descendant.WalkSpeed = 16
            end
        end
    end)
end

runService.RenderStepped:Connect(function()
    if enabled then
        lockEnemies()
    end
end)

updateUI()
