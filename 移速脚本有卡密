-- 踢出函数
local function KickPlayer(reason)
    local player = game:GetService("Players").LocalPlayer
    local reason = reason or "你没有白名单，玩个蛋！"
    
    -- 显示踢出通知
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "❌ 验证失败",
        Text = reason,
        Duration = 5
    })
    
    -- 等待一下让通知显示
    wait(1)
    
    -- 踢出玩家
    player:Kick(reason)
end

-- 验证用户名白名单
local function VerifyUsername()
    local currentUser = game:GetService("Players").LocalPlayer.Name
    local currentUserLower = string.lower(currentUser)
    
    for _, whitelistedUser in ipairs(WhitelistedUsers) do
        if currentUserLower == string.lower(whitelistedUser) then
            return true
        end
    end
    return false
end

