-- ================== 无限跳核心逻辑 ==================
local player = game:GetService("Players").LocalPlayer
local userInputService = game:GetService("UserInputService")
local runService = game:GetService("RunService")

-- 无限跳变量
local jumpCount = 0
local isJumping = false
local flyActive = false
local flyBodyVelocity = nil
local flyBodyGyro = nil

-- 处理跳跃输入
userInputService.JumpRequest:Connect(function()
    if not getgenv().RayfieldSpeed.InfiniteJump then return end
    
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local mode = getgenv().RayfieldSpeed.JumpMode
    
    if mode == "Normal" then
        -- 普通无限跳
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        jumpCount = jumpCount + 1
        
        -- 应用跳跃高度
        humanoid.JumpPower = getgenv().RayfieldSpeed.JumpPower
        
    elseif mode == "SuperJump" then
        -- 超级跳跃（带倍率）
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        jumpCount = jumpCount + 1
        
        local multiplier = getgenv().RayfieldSpeed.JumpMultiplier or 1
        humanoid.JumpPower = getgenv().RayfieldSpeed.JumpPower * multiplier
        
    elseif mode == "Fly" then
        -- 悬浮飞行模式
        if not flyActive then
            flyActive = true
            
            -- 创建BodyVelocity
            if not flyBodyVelocity then
                flyBodyVelocity = Instance.new("BodyVelocity")
                flyBodyVelocity.Name = "FlyVelocity"
                flyBodyVelocity.MaxForce = Vector3.new(4000, 4000, 4000)
                flyBodyVelocity.Velocity = Vector3.new(0, 50, 0)
                flyBodyVelocity.Parent = rootPart
            end
            
            -- 创建BodyGyro保持方向
            if not flyBodyGyro then
                flyBodyGyro = Instance.new("BodyGyro")
                flyBodyGyro.Name = "FlyGyro"
                flyBodyGyro.MaxTorque = Vector3.new(4000, 4000, 4000)
                flyBodyGyro.CFrame = rootPart.CFrame
                flyBodyGyro.Parent = rootPart
            end
            
            -- 持续飞行
            spawn(function()
                while flyActive and getgenv().RayfieldSpeed.InfiniteJump and getgenv().RayfieldSpeed.JumpMode == "Fly" do
                    if userInputService:IsKeyDown(Enum.KeyCode.Space) then
                        if flyBodyVelocity then
                            flyBodyVelocity.Velocity = Vector3.new(0, getgenv().RayfieldSpeed.JumpPower * 2, 0)
                        end
                    else
                        if flyBodyVelocity then
                            flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
                        end
                    end
                    wait(0.1)
                end
                
                -- 清理飞行效果
                if flyBodyVelocity then
                    flyBodyVelocity:Destroy()
                    flyBodyVelocity = nil
                end
                if flyBodyGyro then
                    flyBodyGyro:Destroy()
                    flyBodyGyro = nil
                end
                flyActive = false
            end)
        end
    end
end)

-- 重置跳跃计数（落地时）
local function onCharacterAdded(character)
    local humanoid = character:WaitForChild("Humanoid")
    
    -- 当角色落地时重置跳跃计数
    humanoid.StateChanged:Connect(function(oldState, newState)
        if newState == Enum.HumanoidStateType.Landed then
            jumpCount = 0
            flyActive = false
        end
    end)
end

