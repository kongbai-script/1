-- 已加载脚本记录
local LoadedScriptsSection = StitchTab:CreateSection("已加载记录")
local LoadedScriptsLabel = StitchTab:CreateLabel("暂无加载记录")

-- 更新已加载脚本显示
local function UpdateLoadedScriptsLabel()
    local scripts = getgenv().RayfieldSpeed.LoadedScripts
    if #scripts == 0 then
        LoadedScriptsLabel:Set("暂无加载记录")
    else
        local text = "最近加载:\n"
        for i = math.max(1, #scripts - 4), #scripts do
            local s = scripts[i]
            text = text .. "• " .. s.Time .. " - " .. s.Name .. "\n"
        end
        LoadedScriptsLabel:Set(text)
    end
end

-- 监听脚本加载记录变化
spawn(function()
    while wait(2) do
        UpdateLoadedScriptsLabel()
    end
end)

