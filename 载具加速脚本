local isEnabled = false
local speedMultiplier = 50
local isCollapsed = false
local currentSpeed = 0
local accelerationRate = 1.2
ToggleButton.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    ToggleButton.Text = isEnabled and "加速：开启" or "加速：关闭"
    ToggleButton.TextColor3 = isEnabled and Color3.new(0.2, 0.8, 0.4) or Color3.new(0.8, 0.2, 0.3)
end)
IncreaseButton.MouseButton1Click:Connect(function()
    speedMultiplier += 25
    SpeedLabel.Text = "速度：" .. speedMultiplier
end)
DecreaseButton.MouseButton1Click:Connect(function()
    if speedMultiplier > 25 then
        speedMultiplier -= 25
        SpeedLabel.Text = "速度：" .. speedMultiplier
    end
end)
CollapseButton.MouseButton1Click:Connect(function()
    isCollapsed = not isCollapsed
    if isCollapsed then
        MainFrame.Size = UDim2.new(0, 280, 0, 35)
        SpeedLabel.Visible = false
        DecreaseButton.Visible = false
        IncreaseButton.Visible = false
        ToggleButton.Visible = false
        CollapseButton.Position = UDim2.new(0, 15, 0, 0)
        CollapseButton.Size = UDim2.new(0, 250, 0, 35)
        CollapseButton.Text = "展开GUI"
    else
        MainFrame.Size = UDim2.new(0, 280, 0, 220)
        SpeedLabel.Visible = true
        DecreaseButton.Visible = true
        IncreaseButton.Visible = true
        ToggleButton.Visible = true
        CollapseButton.Position = UDim2.new(0, 15, 0, 175)
        CollapseButton.Size = UDim2.new(0, 250, 0, 35)
        CollapseButton.Text = "收起GUI"
    end
end)
RunService.Heartbeat:Connect(function(dt)
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid or not humanoid.SeatPart then
        currentSpeed = 0
        return
    end
    local seat = humanoid.SeatPart
    if seat:IsA("VehicleSeat") then
        if isEnabled then
            local step = accelerationRate * dt * 60
            currentSpeed = math.clamp(currentSpeed + step, 0, speedMultiplier)
            seat.Velocity = seat.CFrame.LookVector * currentSpeed
            seat.Throttle = 1
        else
            seat.Throttle = 0
        end
    end
end)
