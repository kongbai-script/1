    textBox.Size = UDim2.new(0.8, -20, 0, 45)
    textBox.Position = UDim2.new(0.1, 10, 0, 130)
    textBox.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
    textBox.BackgroundTransparency = 0.2
    textBox.PlaceholderText = "在此输入卡密..."
    textBox.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
    textBox.Text = ""
    textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    textBox.Font = Enum.Font.Gotham
    textBox.TextSize = 18
    textBox.ClearTextOnFocus = false
    textBox.Parent = mainFrame
    
    local boxCorner = Instance.new("UICorner")
    boxCorner.CornerRadius = UDim.new(0, 8)
    boxCorner.Parent = textBox
    
    -- 验证按钮
    local verifyBtn = Instance.new("TextButton")
    verifyBtn.Size = UDim2.new(0.8, -20, 0, 45)
    verifyBtn.Position = UDim2.new(0.1, 10, 0, 190)
    verifyBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 255)
    verifyBtn.Text = "验证卡密"
    verifyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    verifyBtn.Font = Enum.Font.GothamBold
    verifyBtn.TextSize = 18
    verifyBtn.Parent = mainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = verifyBtn
    
    -- 状态显示
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Size = UDim2.new(1, -40, 0, 30)
    statusLabel.Position = UDim2.new(0, 20, 0, 245)
    statusLabel.BackgroundTransparency = 1
    statusLabel.Text = "等待输入..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    statusLabel.Font = Enum.Font.Gotham
    statusLabel.TextSize = 14
    statusLabel.Parent = mainFrame
    
    -- 验证函数
    local function VerifyKey(inputKey)
        for _, validKey in ipairs(ValidKeys) do
            if inputKey == validKey then
                return true
            end
        end
        return false
    end
    
    -- 按钮点击事件
    verifyBtn.MouseButton1Click:Connect(function()
        local input = textBox.Text
        if input == "" then
            statusLabel.Text = "❌ 请输入卡密！"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            return
        end
        
        if VerifyKey(input) then
            statusLabel.Text = "✅ 验证成功！正在加载..."
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            
            -- 延迟后销毁验证UI并加载主程序
            wait(1)
            keyGui:Destroy()
            
            -- 显示成功通知
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "验证成功",
                Text = "欢迎使用速度控制系统",
                Duration = 2
            })
            
            -- 加载主程序
            LoadMainScript()
        else
            statusLabel.Text = "❌ 卡密错误！"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            textBox.Text = ""
        end
    end)
    
    -- 回车键验证
    textBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            verifyBtn.MouseButton1Click:Fire()
        end
    end)
    
    -- 防止点击穿透
    mainFrame.Active = true
    mainFrame.Draggable = true
end

