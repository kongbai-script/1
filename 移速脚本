        elseif input.KeyCode == Enum.KeyCode.Two then
            getgenv().RayfieldSpeed.Speed = 30
            SpeedSlider:Set(30)
            CurrentSpeedLabel:Set("当前速度: 30 单位")
        elseif input.KeyCode == Enum.KeyCode.Three then
            getgenv().RayfieldSpeed.Speed = 50
            SpeedSlider:Set(50)
            CurrentSpeedLabel:Set("当前速度: 50 单位")
        elseif input.KeyCode == Enum.KeyCode.Four then
            getgenv().RayfieldSpeed.Speed = 100
            SpeedSlider:Set(100)
            CurrentSpeedLabel:Set("当前速度: 100 单位")
        end
    end)

    -- 加载完成通知
    Rayfield:Notify({
        Title = "Rayfield 速度系统",
        Content = "按 F8 开启/关闭效果\n输入数字直接设置速度",
        Duration = 5,
        Image = 10734974240
    })

    print("✅ Rayfield UI 速度脚本已加载")
