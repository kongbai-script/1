local rareESPActive=false; local rareESPCache={}
local MP_RARE_ESP_HINT="矿:WorldSpawn→Ores（及 Other 花草）。稀有树:WorldSpawn→Trees 模型名或部件 Material（Nightshade/Goldwood/Glacial/Orewood）。"
local RARE_KEYWORDS={
    {n="Crimsone",    cn="血色矿",   isTree=false},
    {n="Pink Diamond",cn="粉钻",     isTree=false},
    {n="Ancient Rune",cn="古代符文", isTree=false},
    {n="Nightshade",  cn="夜影木",   isTree=true},
    {n="Goldwood",    cn="金木",     isTree=true},
    {n="Glacial",     cn="冰木",     isTree=true},
    {n="Orewood",     cn="矿石树",   isTree=true},
    {n="Flower Grass",cn="花草",     isTree=false},
}
function _G.RC2Fn.addRareHL(model,col,cn)
    if not model or not model:IsA("Model") or rareESPCache[model] then return end
    local hl=Instance.new("Highlight"); hl.OutlineColor=col; hl.FillColor=col
    hl.FillTransparency=0.85; hl.OutlineTransparency=0; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee=model; hl.Parent=model
    local bb=Instance.new("BillboardGui"); bb.Size=UDim2.fromOffset(160,32)
    bb.StudsOffset=Vector3.new(0,7,0); bb.AlwaysOnTop=true; bb.Parent=model
    local bg=Instance.new("Frame",bb); bg.Size=UDim2.fromScale(1,1)
    bg.BackgroundColor3=Color3.fromRGB(8,10,18); bg.BackgroundTransparency=0.15; bg.BorderSizePixel=0
    Instance.new("UICorner",bg).CornerRadius=UDim.new(0,8)
    local lbl=Instance.new("TextLabel",bg); lbl.Size=UDim2.fromScale(1,1)
    lbl.BackgroundTransparency=1; lbl.Text=cn; lbl.TextColor3=col
    lbl.Font=Enum.Font.GothamBold; lbl.TextSize=12
    rareESPCache[model]={hl,bb}
    model.AncestryChanged:Connect(function() if not model:IsDescendantOf(workspace) then
        pcall(function() if hl.Parent then hl:Destroy() end end)
        pcall(function() if bb.Parent then bb:Destroy() end end)
        rareESPCache[model]=nil
    end end)
end
local RARE_COLORS={
    ["Crimsone"]=Color3.fromRGB(220,50,80),["Pink Diamond"]=Color3.fromRGB(255,150,200),
    ["Ancient Rune"]=Color3.fromRGB(100,200,255),["Nightshade"]=Color3.fromRGB(130,0,255),
    ["Goldwood"]=Color3.fromRGB(255,215,0),["Glacial"]=Color3.fromRGB(150,230,255),
    ["Orewood"]=Color3.fromRGB(180,120,60),["Flower Grass"]=Color3.fromRGB(100,220,80),
}
function _G.RC2Fn.scanRareESP()
    if not rareESPActive then return end
    local ws=workspace:FindFirstChild("WorldSpawn")
    if not ws then return end
    local treesF=ws:FindFirstChild("Trees")
    if treesF then
    for _,rare in ipairs(RARE_KEYWORDS) do
            if not rare.isTree then continue end
            local needle=rare.n:lower()
            _G.RC2Fn.forEachMineModelInFolder(treesF,function(m)
                local mn=m.Name:lower()
                local hit=(m.Name==rare.n or mn:find(needle,1,true))
                if not hit then
                    for _,d in ipairs(m:GetDescendants()) do
                        if d:IsA("BasePart") then
                            local mat=tostring(d:GetAttribute("Material") or "")
                            if mat==rare.n or (mat~="" and mat:lower():find(needle,1,true)) then hit=true break end
                        end
                    end
                end
                if hit then _G.RC2Fn.addRareHL(m,RARE_COLORS[rare.n] or Color3.fromRGB(255,255,255),rare.cn) end
            end)
        end
    end
    for _,rare in ipairs(RARE_KEYWORDS) do
        if rare.isTree then continue end
        local folder=ws:FindFirstChild(rare.n=="Flower Grass" and "Other" or "Ores")
        if not folder then folder=ws:FindFirstChild("Other") end
        if not folder then continue end
        local needle=rare.n:lower()
        for _,m in pairs(folder:GetDescendants()) do
            if not m:IsA("Model") then continue end
            local mn=m.Name:lower()
            if m.Name==rare.n or mn:find(needle,1,true) then
                _G.RC2Fn.addRareHL(m, RARE_COLORS[rare.n] or Color3.fromRGB(255,255,255), rare.cn)
            end
        end
    end
end
task.spawn(function() while true do task.wait(5); if rareESPActive then pcall(_G.RC2Fn.scanRareESP) end end end)

