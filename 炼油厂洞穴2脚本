    local rx=(math.random()*2-1)*0.45
    local ry=(math.random()*2-1)*0.45
    local rz=(math.random()*2-1)*0.45
    return cf:PointToWorldSpace(Vector3.new(rx*s.X*0.5,ry*s.Y*0.5,rz*s.Z*0.5))
end
function _G.RC2Fn.partMinWorldY(p)
    if not p or not p:IsA("BasePart") then return math.huge end
    local cf=p.CFrame
    local hx,hy,hz=p.Size.X*0.5,p.Size.Y*0.5,p.Size.Z*0.5
    local miny=math.huge
    for _,sx in ipairs({-hx,hx}) do
        for _,sy in ipairs({-hy,hy}) do
            for _,sz in ipairs({-hz,hz}) do
                local y=(cf*Vector3.new(sx,sy,sz)).Y
                if y<miny then miny=y end
            end
        end
    end
    return miny
end
function _G.RC2Fn.collectHittablePartsNamedPart(model)
    local h=model and model:FindFirstChild("Hittable")
    if not h then return {} end
    local named={}
    for _,d in pairs(h:GetDescendants()) do
        if d.Name=="Part" then
            if d:IsA("BasePart") then table.insert(named,d)
            elseif d:IsA("Model") then
                local pp=d.PrimaryPart or d:FindFirstChildWhichIsA("BasePart",true)
                if pp then table.insert(named,pp) end
