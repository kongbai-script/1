local function MP_findAirflowWindowGui()
    if MP_airflowWindowGuiCache and MP_airflowWindowGuiCache.Parent then return MP_airflowWindowGuiCache end
    MP_airflowWindowGuiCache=nil
    local function isWin(ch)
        return ch:IsA("ScreenGui") and type(ch.Name)=="string" and ch.Name:sub(1,9)==".Airflow="
    end
    local cg=game:GetService("CoreGui")
    for _,ch in ipairs(cg:GetDescendants()) do
        if isWin(ch) then MP_airflowWindowGuiCache=ch return ch end
    end
    local gh=rawget(_G,"gethui")
    if type(gh)=="function" then
        local ok,h=pcall(gh)
        if ok and h then
            for _,ch in ipairs(h:GetDescendants()) do
                if isWin(ch) then MP_airflowWindowGuiCache=ch return ch end
            end
        end
    end
    local lp=game:GetService("Players").LocalPlayer
    local pg=lp and lp:FindFirstChild("PlayerGui")
    if pg then
        for _,ch in ipairs(pg:GetDescendants()) do
            if isWin(ch) then MP_airflowWindowGuiCache=ch return ch end
        end
    end
    return nil
end
local function MP_findAirflowWindowFrameInScreenGui(sg)
    if not sg then return nil end
    for _,f in ipairs(sg:GetChildren()) do
        if f:IsA("Frame") then
            for _,c in ipairs(f:GetChildren()) do
                if c:IsA("Frame") and math.abs(c.AnchorPoint.Y-1)<0.01 and c.Position.Y.Scale>0.98 and c.Size.Y.Offset==-40 then
                    return f
                end
            end
        end
    end
    for _,f in ipairs(sg:GetChildren()) do
        if f:IsA("Frame") then
            for _,c in ipairs(f:GetChildren()) do
                if c:IsA("Frame") and c.Size.Y.Offset==30 and math.abs(c.Position.Y.Offset-5)<=2 then return f end
            end
        end
    end
    return nil
end
