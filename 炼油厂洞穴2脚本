local NET_WORK_ATTR_KEYS={"_NetWork","_Network","NetWork","Network"}
function _G.RC2Fn.attrNetWorkReady(v)
    if v==nil then return false end
    if v==true or v==1 or v=="1" then return true end
    if typeof(v)=="number" and v~=0 then return true end
    if typeof(v)=="string" then
        local s=string.lower(v)
        if s=="" or s=="0" or s=="false" then return false end
        return true
    end
    return false
end
function _G.RC2Fn.instanceHasNetWorkAttr(inst)
    if not inst then return false end
    for _,key in ipairs(NET_WORK_ATTR_KEYS) do
        if _G.RC2Fn.attrNetWorkReady(inst:GetAttribute(key)) then return true end
    end
    return false
end
local PRIMARY_NET_STATE_KEYS={"_NetWork","_Network"}
function _G.RC2Fn.instancePrimaryNetStateReady(inst)
    if not inst then return false end
    for _,key in ipairs(PRIMARY_NET_STATE_KEYS) do
        if _G.RC2Fn.attrNetWorkReady(inst:GetAttribute(key)) then return true end
    end
    return false
end
function _G.RC2Fn.modelHasNetWorkStateReady(m)
    if not m then return false end
    if _G.RC2Fn.instancePrimaryNetStateReady(m) then return true end
    for _,d in ipairs(m:GetDescendants()) do
        if _G.RC2Fn.instancePrimaryNetStateReady(d) then return true end
    end
    return false
end
function _G.RC2Fn.grabInvokePartFor(it)
    if not it or not it.model then return it and it.part end
    return _G.RC2Fn.getInvokeGrabPart(it.model,it.part) or it.part
end
function _G.RC2Fn.itemHasNetWorkReadyForTeleport(it,packAny)
    if packAny then return true end
    if not it.model or not it.model.Parent then return false end
    return _G.RC2Fn.modelHasNetWorkStateReady(it.model)
end
function _G.RC2Fn.waitActiveAllParallel(batch)
    if not batch or #batch==0 then return end
    local n=#batch
    local done={}
    for i=1,n do done[i]=false end
    for i,it in ipairs(batch) do
        local itHold=it
        local idx=i
        task.spawn(function()
            if itHold.model and itHold.model.Parent then _G.RC2Fn.waitActive(itHold.model) end
            done[idx]=true
        end)
    end
    local t0=tick()
    repeat
        task.wait(0.04)
        local ok=true
        for j=1,n do if not done[j] then ok=false; break end end
        if ok then return end
    until tick()-t0>2.8
end
function _G.RC2Fn.waitBatchProximityAutoNetWork(batch,packAny)
    if packAny then return end
    local t0=tick()
    local lastNudge=t0
    while tick()-t0<NET_AUTO_WAIT_MAX do
        if _G.RC2Fn.mpShouldAbort() then return end
        local all=true
        for _,it in ipairs(batch) do
        if not it.model or not it.model.Parent then continue end
            if _G.RC2Fn.itemHasNetWorkReadyForTeleport(it,false) then continue end
            all=false; break
        end
        if all then return end
        if tick()-lastNudge>=NET_SOFT_GRAB_INTERVAL then
            lastNudge=tick()
            for _,it in ipairs(batch) do
                if it.model and it.model.Parent and not _G.RC2Fn.itemHasNetWorkReadyForTeleport(it,false) then
                    local pr=_G.RC2Fn.grabInvokePartFor(it)
                    if pr and pr.Parent then pcall(function() _G.RC2Fn.grabRemoteGrab(it.model,pr) end) end
                end
            end
        end
        task.wait(NET_AUTO_POLL)
    end
end
function _G.RC2Fn.waitUntilAllGrabPrimariesNetworkLocal(list)
    if not list or #list==0 then return true end
    local t0=tick()
    local lastNudge=t0
    while tick()-t0<GRAB_NETOWNER_MAX_WAIT do
        if _G.RC2Fn.mpShouldAbort() then return false end
        local all=true
        for _,it in ipairs(list) do
            if not it.model or not it.model.Parent then all=false; break end
            local pr=_G.RC2Fn.grabInvokePartFor(it)
            if not pr or not pr.Parent then all=false; break end
            if _G.RC2Fn.itemHasNetWorkReadyForTeleport(it,false) then continue end
            all=false
        end
        if all then return true end
        if tick()-lastNudge>=NET_SOFT_GRAB_INTERVAL then
            lastNudge=tick()
            for _,it in ipairs(list) do
                if it.model and it.model.Parent and not _G.RC2Fn.itemHasNetWorkReadyForTeleport(it,false) then
                    local pr=_G.RC2Fn.grabInvokePartFor(it)
                    if pr and pr.Parent then pcall(function() _G.RC2Fn.grabRemoteGrab(it.model,pr) end) end
                end
            end
        end
        task.wait(0.06)
    end
    for _,it in ipairs(list) do
        if it.model and it.model.Parent and _G.RC2Fn.itemHasNetWorkReadyForTeleport(it,false) then continue end
        return false
    end
    return true
end
function _G.RC2Fn.characterHasNetworkAuthority()
    local ch=player.Character
    if not ch or not ch.Parent then return false end
    local hrp0=ch:FindFirstChild("HumanoidRootPart")
    if hrp0 and hrp0:IsA("BasePart") then
        local ok,own=pcall(function() return hrp0:GetNetworkOwner() end)
        if ok and own==player then return true end
        if _G.RC2Fn.instanceHasNetWorkAttr(hrp0) then return true end
    end
    local hum=ch:FindFirstChildOfClass("Humanoid")
    if hum and _G.RC2Fn.instanceHasNetWorkAttr(hum) then return true end
    if _G.RC2Fn.instanceHasNetWorkAttr(ch) then return true end
    if _G.RC2Fn.instanceHasNetWorkAttr(player) then return true end
    return hrp0~=nil
end
function _G.RC2Fn.waitUntilCharacterNetworkReady(maxW)
    maxW=maxW or CHARACTER_NET_MAX_WAIT
    if _G.RC2Fn.characterHasNetworkAuthority() then return true end
    local t0=tick()
    while tick()-t0<maxW do
        task.wait(CHARACTER_NET_POLL)
        if _G.RC2Fn.characterHasNetworkAuthority() then return true end
    end
    return false
end
function _G.RC2Fn.tupleNearDest(it,destPos,studs)
    if not it.model or not it.model.Parent then return true end
    studs=studs or TRANSPORT_DEST_OK_STUDS
    return (it.model:GetPivot().Position-destPos).Magnitude<=studs
end

_G.RC2_MPXfer=_G.RC2_MPXfer or {}
