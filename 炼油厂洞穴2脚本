    local function considerModel(m)
        for _,p in pairs(_G.RC2Fn.collectHittableBaseParts(m)) do
            local d=(p.Position-hrp.Position).Magnitude
            if d<bestD then bestD=d; bestP=p.Position end
        end
    end
    _G.RC2Fn.forEachMineModelInFolder(oresF,considerModel)
    local choc=oresF:FindFirstChild("Chocolate",true)
    if choc then considerModel(choc) end
    return bestP
end

