            if #selKw==0 then return end
            local any=false
            for _,k in ipairs(selKw) do
                local ks=tostring(k or "")
                if ks~="" and (m.Name==ks or m.Name:lower():find(ks:lower(),1,true)) then any=true break end
            end
            if not any then return end
        elseif selKw~="" then
            if m.Name~=selKw and not m.Name:lower():find(selKw:lower(),1,true) then return end
        end
    end
    local parts=_G.RC2Fn.collectHittableBaseParts(m)
