local chocCarrotESPActive=false
local chocCarrotCache={}
function _G.RC2Fn.addChocCarrotHL(model,col,cn)
    if not model or not model:IsA("Model") or chocCarrotCache[model] then return end
    local hl=Instance.new("Highlight"); hl.OutlineColor=col; hl.FillColor=col
    hl.FillTransparency=0.85; hl.OutlineTransparency=0; hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee=model; hl.Parent=model
    local bb=Instance.new("BillboardGui"); bb.Size=UDim2.fromOffset(180,32)
    bb.StudsOffset=Vector3.new(0,8,0); bb.AlwaysOnTop=true; bb.Parent=model
    local bg=Instance.new("Frame",bb); bg.Size=UDim2.fromScale(1,1)
    bg.BackgroundColor3=Color3.fromRGB(8,10,18); bg.BackgroundTransparency=0.15; bg.BorderSizePixel=0
    Instance.new("UICorner",bg).CornerRadius=UDim.new(0,8)
    local lbl=Instance.new("TextLabel",bg); lbl.Size=UDim2.fromScale(1,1)
    lbl.BackgroundTransparency=1; lbl.Text=cn; lbl.TextColor3=col
    lbl.Font=Enum.Font.GothamBold; lbl.TextSize=12
    chocCarrotCache[model]={hl,bb}
    model.AncestryChanged:Connect(function() if not model:IsDescendantOf(workspace) then
        pcall(function() if hl.Parent then hl:Destroy() end end)
        pcall(function() if bb.Parent then bb:Destroy() end end)
        chocCarrotCache[model]=nil
    end end)
end
function _G.RC2Fn.nameLooksChocolate(m)
    local n=m.Name:lower()
    return m.Name=="Chocolate" or n:find("chocolate",1,true)~=nil
end
function _G.RC2Fn.nameLooksCarroot(m)
    local n=m.Name:lower()
    return m.Name=="Carroot" or n:find("carroot",1,true)~=nil or n:find("carrot",1,true)~=nil
end

function _G.RC2Fn.scanChocCarrotESP()
    if not chocCarrotESPActive then return end
    local ws=workspace:FindFirstChild("WorldSpawn"); if not ws then return end
    local colC=Color3.fromRGB(200,95,55)
    local colT=Color3.fromRGB(255,150,60)
    local ores=ws:FindFirstChild("Ores")
    if ores then
        local chRoot=ores:FindFirstChild("Chocolate",true)
        if chRoot then
            if chRoot:IsA("Folder") then
                for _,d in pairs(chRoot:GetDescendants()) do
                    if d:IsA("Model") then _G.RC2Fn.addChocCarrotHL(d,colC,"巧克力矿") end
                end
            elseif chRoot:IsA("Model") then
                _G.RC2Fn.addChocCarrotHL(chRoot,colC,"巧克力矿")
            end
        end
        for _,m in pairs(ores:GetChildren()) do
            if m:IsA("Model") and _G.RC2Fn.nameLooksChocolate(m) and m~=chRoot then _G.RC2Fn.addChocCarrotHL(m,colC,"巧克力矿") end
        end
    end
    local trees=ws:FindFirstChild("Trees")
    if trees then
        local crRoot=trees:FindFirstChild("Carroot",true)
        if crRoot then
            if crRoot:IsA("Folder") then
                for _,d in pairs(crRoot:GetDescendants()) do
                    if d:IsA("Model") then _G.RC2Fn.addChocCarrotHL(d,colT,"胡萝卜树") end
                end
            elseif crRoot:IsA("Model") then
                _G.RC2Fn.addChocCarrotHL(crRoot,colT,"胡萝卜树")
            end
        end
        for _,m in pairs(trees:GetChildren()) do
            if m:IsA("Model") and _G.RC2Fn.nameLooksCarroot(m) and m~=crRoot then _G.RC2Fn.addChocCarrotHL(m,colT,"胡萝卜树") end
        end
    end
end
