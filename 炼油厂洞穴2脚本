local MP_AIRFLOW_URL="https://raw.githubusercontent.com/4lpaca-pin/Airflow/refs/heads/main/src/source.luau"
local function MP_loadAirflow()
    local body
    local ok,r=pcall(function() return game:HttpGetAsync(MP_AIRFLOW_URL) end)
    if ok and type(r)=="string" and #r>2000 then body=r end
    if not body then
        ok,r=pcall(function() return game:HttpGet(MP_AIRFLOW_URL,true) end)
        if ok and type(r)=="string" and #r>2000 then body=r end
    end
    if not body then error("[MoonPixel] Airflow 下载失败："..tostring(MP_AIRFLOW_URL)) end
    local ok2,mod=pcall(function() return loadstring(body,"@Airflow")() end)
    if not ok2 or type(mod)~="table" then error("[MoonPixel] Airflow 执行失败："..tostring(mod)) end
    return mod
end
