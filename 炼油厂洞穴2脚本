        local hum=ch and ch:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand=false end
        vflyPos=nil
        local root=select(1,getAssemblyRoot())
        if root and root.Parent then
            pcall(function() root.AssemblyLinearVelocity=Vector3.zero end)
            pcall(function() root.AssemblyAngularVelocity=Vector3.zero end)
        end
        pcall(function() workspace.CurrentCamera.CameraType=Enum.CameraType.Custom end)
    end
    local function startVFly()
        if FLYING then return end
        FLYING=true
        vflyPos=nil
        hbConn=RunService.Heartbeat:Connect(function(dt)
            if not FLYING then return end
            if UserInputService:GetFocusedTextBox()~=nil then return end
            local root,hum=getAssemblyRoot()
            if not root or not root.Parent then return end
            local step=(typeof(dt)=="number" and dt>0 and dt<0.25) and dt or (1/60)
            local cam=workspace.CurrentCamera
            if not cam then return end
            if hum and not hum.SeatPart then hum.PlatformStand=true end
            local mult=speeds
            local sp=BASE_STUDS*mult
            local look=cam.CFrame.LookVector
            local rightV=cam.CFrame.RightVector
            local hL=Vector3.new(look.X,0,look.Z)
            if hL.Magnitude>1e-4 then hL=hL.Unit else hL=Vector3.new(0,0,-1) end
            local hR=Vector3.new(rightV.X,0,rightV.Z)
            if hR.Magnitude>1e-4 then hR=hR.Unit else hR=Vector3.new(1,0,0) end
            local f,s=0,0
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then f+=1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then f-=1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then s+=1 end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then s-=1 end
            local mv=Vector3.zero
            if f~=0 or s~=0 then
                mv=look*f+rightV*s
            else
                local md=hum and hum.MoveDirection or Vector3.zero
                local mdH=Vector3.new(md.X,0,md.Z)
                if mdH.Magnitude>0.04 then
                    mv=look*mdH:Dot(hL)+rightV*mdH:Dot(hR)
                end
            end
            if btnUpHeld then mv+=Vector3.new(0,1,0) end
            if btnDownHeld then mv-=Vector3.new(0,1,0) end
            if not vflyPos then vflyPos=root.Position end
            if mv.Magnitude>1e-4 then
                vflyPos=vflyPos+mv.Unit*sp*step
            end
            pcall(function()
                local cf=root.CFrame
                local rotOnly=cf-cf.Position
                root.CFrame=CFrame.new(vflyPos)*rotOnly
                root.AssemblyLinearVelocity=Vector3.zero
                root.AssemblyAngularVelocity=Vector3.zero
            end)
        end)
    end
