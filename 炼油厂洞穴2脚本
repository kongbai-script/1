local GRAB_WALK_MAX_DEPTH=32

function _G.RC2Fn.forEachGrabOreOrWoodModel(grabRoot,callback)
    if not grabRoot or not callback then return end
    local function walk(node,depth)
        if depth>GRAB_WALK_MAX_DEPTH then return end
        for _,c in pairs(node:GetChildren()) do
            if c:IsA("Model") then
                if c.Name=="MaterialPart" or c.Name=="WoodPart" then pcall(function() callback(c) end)
                else walk(c,depth+1) end
            elseif c:IsA("Folder") then walk(c,depth+1) end
        end
    end
    walk(grabRoot,0)
end
function _G.RC2Fn.forEachGrabModelDeep(grabRoot,callback)
    if not grabRoot or not callback then return end
    local function walk(node,depth)
        if depth>GRAB_WALK_MAX_DEPTH then return end
        for _,c in pairs(node:GetChildren()) do
            if c:IsA("Model") then pcall(function() callback(c) end); walk(c,depth+1)
            elseif c:IsA("Folder") then walk(c,depth+1) end
        end
    end
    walk(grabRoot,0)
end
