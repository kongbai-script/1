    if not _G.RC2Fn.characterHasNetworkAuthority() then _G.RC2Fn.waitUntilCharacterNetworkReady(CHARACTER_NET_MAX_WAIT) end
    RunService.Heartbeat:Wait()
    _G.RC2_MPXfer.pivotModelsToDest(destPos,list,lift)
    _G.RC2_MPXfer.ungrabList(list)
    _G.RC2_MPXfer.movePlayerToLift(lift)
    return _G.RC2_MPXfer.countArrived(list,destPos,arriveStuds)
end

function _G.RC2Fn.refreshGrabTuplePart(it)
    if not it or not it.model or not it.model.Parent then return false end
    if it.part and it.part.Parent and it.part:IsDescendantOf(it.model) then return true end
    local m=it.model
    local n=m.Name
    if n=="MaterialPart" then
        local p=_G.RC2Fn.grabTeleportPartForModel(m) or _G.RC2Fn.getMaterialPart(m)
        if p and p.Parent then it.part=p; return true end
        return false
    end
    if n=="WoodPart" then
        local p=_G.RC2Fn.grabTeleportPartForModel(m) or _G.RC2Fn.getWoodPartModel(m)
        if p and p.Parent then it.part=p; return true end
        return false
    end
    local p=_G.RC2Fn.grabTeleportPartForModel(m) or _G.RC2Fn.getPart(m)
    if p and p.Parent then it.part=p; return true end
    return false
end

function _G.RC2_MPXfer.buildInitial(items,destPos,destArriveStuds)
    local sent=0
    local pending={}
    for _,it in ipairs(items) do
        if it.model and it.model.Parent and it.part then
            _G.RC2Fn.refreshGrabTuplePart(it)
            if not it.part or not it.part.Parent then continue end
            originalPositions[tostring(it.model)]=it.model:GetPivot().Position
            if _G.RC2Fn.grabExcludedByAnchorChamber(it.model,it.part) then continue end
            if not _G.RC2Fn.grabTupleModelOwnerIsLocal(it.model) then continue end
            if _G.RC2Fn.tupleNearDest(it,destPos,destArriveStuds) then sent+=1; continue end
            table.insert(pending,it)
        end
    end
    return sent,pending
end
function _G.RC2_MPXfer.cullAlive(pending,destPos,destArriveStuds)
    local sentAdd=0
        local alive={}
        for _,it in ipairs(pending) do
        if it.model and it.model.Parent then
            _G.RC2Fn.refreshGrabTuplePart(it)
            if it.part and it.part.Parent then
                if not _G.RC2Fn.grabTupleModelOwnerIsLocal(it.model) then continue end
                if _G.RC2Fn.tupleNearDest(it,destPos,destArriveStuds) then sentAdd+=1
                else table.insert(alive,it) end
            end
        end
    end
    return alive,sentAdd
end
function _G.RC2_MPXfer.splitRanges(pending,hrp,r2)
    local inRange={}
    local outRange={}
    for _,it in ipairs(pending) do
        if not it.model or not it.model.Parent then continue end
        if not _G.RC2Fn.grabTupleModelOwnerIsLocal(it.model) then continue end
        if not _G.RC2Fn.refreshGrabTuplePart(it) or not it.part or not it.part.Parent then continue end
        local d=it.part.Position-hrp.Position
        if d.X*d.X+d.Y*d.Y+d.Z*d.Z<=r2 then table.insert(inRange,it)
        else table.insert(outRange,it) end
    end
    return inRange,outRange
end
function _G.RC2_MPXfer.nudgeGrabInRange(inRange,packAny)
    if packAny then return end
    for _,it in ipairs(inRange) do
        if it.model and it.model.Parent and not _G.RC2Fn.itemHasNetWorkReadyForTeleport(it,false) then
            local pr=_G.RC2Fn.grabInvokePartFor(it)
            if pr and pr.Parent then pcall(function() _G.RC2Fn.grabRemoteGrab(it.model,pr) end) end
        end
    end
end
function _G.RC2_MPXfer.collectOwned(inRange,packAny)
    local owned={}
    for _,it in ipairs(inRange) do
        if _G.RC2Fn.itemHasNetWorkReadyForTeleport(it,packAny) then table.insert(owned,it) end
    end
    return owned
end
function _G.RC2_MPXfer.mergePendingRetry(outRange,inRange)
    local pending={}
    for _,it in ipairs(outRange) do table.insert(pending,it) end
    for _,it in ipairs(inRange) do table.insert(pending,it) end
    return pending
end
function _G.RC2_MPXfer.rebuildPendingAfterMove(outRange,inRange,destPos,destArriveStuds)
    local pending={}
    for _,it in ipairs(outRange) do table.insert(pending,it) end
    for _,it in ipairs(inRange) do
        if not _G.RC2Fn.tupleNearDest(it,destPos,destArriveStuds) then table.insert(pending,it) end
    end
    return pending
end
function _G.RC2_MPXfer.tryTeleportBatch(destPos,owned,packAny,destArriveStuds,skipFailRetry,woodFast)
    local moved
    if woodFast then
        moved=_G.RC2_MPXfer.batchTeleportWoodFast(destPos,owned,destArriveStuds)
    else
        moved=_G.RC2_MPXfer.batchTeleport(destPos,owned,packAny,destArriveStuds)
    end
    if not skipFailRetry and moved==0 and #owned>0 and not packAny then
        _G.RC2Fn.waitBatchProximityAutoNetWork(owned,packAny)
        if woodFast then
            moved=_G.RC2_MPXfer.batchTeleportWoodFast(destPos,owned,destArriveStuds)
        else
            moved=_G.RC2_MPXfer.batchTeleport(destPos,owned,packAny,destArriveStuds)
        end
    end
    return moved
end

function _G.RC2_MPXfer.transportBringSinglePass(items,destPos,woodFast)
    if #items==0 then return 0 end
    _G.RC2Fn.normalizeGrabTeleportTuples(items)
    if not destPos then destPos=Vector3.new(0,10,0) end
    local destArriveStuds=TRANSPORT_DEST_OK_STUDS
    if (destPos-SELL_POS).Magnitude<2 then destArriveStuds=SELL_DEST_OK_STUDS end
    local function countBrought()
        local n=0
    for _,it in ipairs(items) do
            _G.RC2Fn.refreshGrabTuplePart(it)
            if it.model and it.model.Parent and it.part and it.part.Parent and _G.RC2Fn.grabTupleModelOwnerIsLocal(it.model) and not _G.RC2Fn.grabExcludedByAnchorChamber(it.model,it.part) and _G.RC2Fn.tupleNearDest(it,destPos,destArriveStuds) then n+=1 end
        end
        return n
    end
    local r2=MP_SELECT_ITEM_TP_RADIUS_STUDS*MP_SELECT_ITEM_TP_RADIUS_STUDS
    local _,pending=_G.RC2_MPXfer.buildInitial(items,destPos,destArriveStuds)
    if #pending==0 then return countBrought() end
    if _G.RC2Fn.mpShouldAbort() then return countBrought() end
    local hrp=_G.RC2Fn.getHRP()
    if not hrp then return countBrought() end
        table.sort(pending,function(a,b)
        local pa=(a.part and a.part.Parent and a.part.Position) or hrp.Position
        local pb=(b.part and b.part.Parent and b.part.Position) or hrp.Position
        return (pa-hrp.Position).Magnitude<(pb-hrp.Position).Magnitude
    end)
    local anchor=pending[1]
    if anchor.part and anchor.part.Parent then
        hrp.CFrame=CFrame.new(anchor.part.Position+Vector3.new(0,4,0))
        task.wait(woodFast and 0.03 or 0.12)
    end
    if _G.RC2Fn.mpShouldAbort() then return countBrought() end
    hrp=_G.RC2Fn.getHRP()
    if not hrp then return countBrought() end
    local inRange=_G.RC2_MPXfer.splitRanges(pending,hrp,r2)
    if #inRange==0 then return countBrought() end
    if woodFast then
        _G.RC2_MPXfer.nudgeGrabInRange(inRange,false)
        task.wait(0.02)
    else
        _G.RC2Fn.waitActiveAllParallel(inRange)
        if _G.RC2Fn.mpShouldAbort() then return countBrought() end
        _G.RC2_MPXfer.nudgeGrabInRange(inRange,false)
        _G.RC2Fn.waitBatchProximityAutoNetWork(inRange,false)
    end
    if _G.RC2Fn.mpShouldAbort() then return countBrought() end
    local owned=_G.RC2_MPXfer.collectOwned(inRange,false)
    if #owned>0 then
        _G.RC2_MPXfer.tryTeleportBatch(destPos,owned,false,destArriveStuds,true,woodFast)
    end
    return countBrought()
end

function _G.RC2_MPXfer.transportOneShot(items,destPos,_packAnyIgnored,maxTeleportRoundsPerModel,woodFast)
    if #items==0 then return 0 end
    _G.RC2Fn.normalizeGrabTeleportTuples(items)
    if not destPos then destPos=Vector3.new(0,10,0) end
    local destArriveStuds=TRANSPORT_DEST_OK_STUDS
    if (destPos-SELL_POS).Magnitude<2 then destArriveStuds=SELL_DEST_OK_STUDS end
    local r2=MP_SELECT_ITEM_TP_RADIUS_STUDS*MP_SELECT_ITEM_TP_RADIUS_STUDS
    local tpRounds={}
    local maxTp=maxTeleportRoundsPerModel
    if type(maxTp)~="number" or maxTp<1 then maxTp=nil end
    local sent,pending=_G.RC2_MPXfer.buildInitial(items,destPos,destArriveStuds)
    while #pending>0 do
        if _G.RC2Fn.mpShouldAbort() then break end
        local add
        pending,add=_G.RC2_MPXfer.cullAlive(pending,destPos,destArriveStuds)
        sent+=add
        if maxTp then
            local pruned={}
            for _,it in ipairs(pending) do
                if (tpRounds[it.model] or 0)<maxTp then table.insert(pruned,it) end
            end
            pending=pruned
        end
        if #pending==0 then break end
        local hrp=_G.RC2Fn.getHRP()
        if not hrp then break end
        local hrpPos=hrp.Position
        table.sort(pending,function(a,b)
            local pa=(a.part and a.part.Parent and a.part.Position) or hrpPos
            local pb=(b.part and b.part.Parent and b.part.Position) or hrpPos
            return (pa-hrpPos).Magnitude<(pb-hrpPos).Magnitude
        end)
        local anchor=pending[1]
        if anchor.part and anchor.part.Parent then
            hrp.CFrame=CFrame.new(anchor.part.Position+Vector3.new(0,4,0))
            task.wait(woodFast and 0.03 or 0.12)
        end
        if _G.RC2Fn.mpShouldAbort() then break end
        hrp=_G.RC2Fn.getHRP()
        if not hrp then break end
        local inRange,outRange=_G.RC2_MPXfer.splitRanges(pending,hrp,r2)
        if #inRange==0 then
            task.wait(woodFast and 0.03 or 0.08)
            pending=_G.RC2_MPXfer.mergePendingRetry(outRange,{})
            continue
        end
        if woodFast then
            _G.RC2_MPXfer.nudgeGrabInRange(inRange,false)
            task.wait(0.02)
        else
            _G.RC2Fn.waitActiveAllParallel(inRange)
            if _G.RC2Fn.mpShouldAbort() then break end
            _G.RC2_MPXfer.nudgeGrabInRange(inRange,false)
            _G.RC2Fn.waitBatchProximityAutoNetWork(inRange,false)
        end
        if _G.RC2Fn.mpShouldAbort() then break end
        local owned=_G.RC2_MPXfer.collectOwned(inRange,false)
        if #owned==0 then
            pending=_G.RC2_MPXfer.mergePendingRetry(outRange,inRange)
            task.wait(woodFast and 0.04 or 0.1)
            continue
        end
        local skipInnerRetry=maxTp~=nil
        local moved=_G.RC2_MPXfer.tryTeleportBatch(destPos,owned,false,destArriveStuds,skipInnerRetry,woodFast)
        if maxTp then for _,it in ipairs(owned) do tpRounds[it.model]=(tpRounds[it.model] or 0)+1 end end
        sent+=moved
        pending=_G.RC2_MPXfer.rebuildPendingAfterMove(outRange,inRange,destPos,destArriveStuds)
    end
    return sent
end

function _G.RC2_MPXfer.transport(items,destPos,packAny,maxOuterPasses,skipFailRetry)
    if #items==0 then return 0 end
    _G.RC2Fn.normalizeGrabTeleportTuples(items)
    if not destPos then destPos=Vector3.new(0,10,0) end
    local passLimit=maxOuterPasses or TRANSPORT_MAX_OUTER_PASSES
    local destArriveStuds=TRANSPORT_DEST_OK_STUDS
    if (destPos-SELL_POS).Magnitude<2 then destArriveStuds=SELL_DEST_OK_STUDS end
    local hrp=_G.RC2Fn.getHRP(); if not hrp then return 0 end
    local sent,pending=_G.RC2_MPXfer.buildInitial(items,destPos,destArriveStuds)
    if #pending==0 then return sent end
    local r2=MP_SELECT_ITEM_TP_RADIUS_STUDS*MP_SELECT_ITEM_TP_RADIUS_STUDS
    for _=1,passLimit do
        if _G.RC2Fn.mpShouldAbort() then break end
        local add; pending,add=_G.RC2_MPXfer.cullAlive(pending,destPos,destArriveStuds); sent+=add
        if #pending==0 then break end
        hrp=_G.RC2Fn.getHRP(); if not hrp then break end
        table.sort(pending,function(a,b)
            return (a.part.Position-hrp.Position).Magnitude<(b.part.Position-hrp.Position).Magnitude
        end)
        local anchor=pending[1]
        hrp.CFrame=CFrame.new(anchor.part.Position+Vector3.new(0,4,0))
        task.wait(0.06)
        if _G.RC2Fn.mpShouldAbort() then break end
        hrp=_G.RC2Fn.getHRP(); if not hrp then break end
        local inRange,outRange=_G.RC2_MPXfer.splitRanges(pending,hrp,r2)
        if #inRange==0 then task.wait(0.05); continue end
        _G.RC2Fn.waitActiveAllParallel(inRange)
        if _G.RC2Fn.mpShouldAbort() then break end
        _G.RC2_MPXfer.nudgeGrabInRange(inRange,packAny)
        _G.RC2Fn.waitBatchProximityAutoNetWork(inRange,packAny)
        if _G.RC2Fn.mpShouldAbort() then break end
        local owned=_G.RC2_MPXfer.collectOwned(inRange,packAny)
        if #owned==0 then
            pending=_G.RC2_MPXfer.mergePendingRetry(outRange,inRange)
            task.wait(0.08)
            continue
        end
        if _G.RC2Fn.mpShouldAbort() then break end
        local moved=_G.RC2_MPXfer.tryTeleportBatch(destPos,owned,packAny,destArriveStuds,skipFailRetry)
        sent+=moved
        if skipFailRetry and moved==0 and #owned>0 and not packAny then break end
        pending=_G.RC2_MPXfer.rebuildPendingAfterMove(outRange,inRange,destPos,destArriveStuds)
    end
    return sent
end

