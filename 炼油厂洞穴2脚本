function _G.RC2Fn.getAllGrabRoots()
    local t=tick()
    if _grabRootsCache and t-_grabRootsCacheT<GRAB_ROOT_CACHE_SEC then return _grabRootsCache end
    local roots={}
    local seen={}
    local function add(x)
        if not x or seen[x] then return end
        if not (x:IsA("Folder") or x:IsA("Model")) then return end
        seen[x]=true
        table.insert(roots,x)
    end
    for _,inst in ipairs(workspace:GetDescendants()) do
        if inst.Name=="Grab" then add(inst) end
    end
    _grabRootsCache=roots
    _grabRootsCacheT=t
    return roots
end
