    local function getAssemblyRoot()
        local ch=player.Character
        local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
        if not hrp or not hrp:IsA("BasePart") then return nil,nil end
        local root=hrp.AssemblyRootPart
