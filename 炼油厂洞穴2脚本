function _G.RC2Fn.tuplesNearFeedOrMachine(items,feedPos,machinePos,maxDist)
    maxDist=maxDist or 55
    local r2=maxDist*maxDist
    local out={}
    for _,it in ipairs(items) do
        _G.RC2Fn.refreshGrabTuplePart(it)
        if not it.part or not it.part.Parent then continue end
        local p=it.part.Position
        local df=p-feedPos
        local dm=p-machinePos
        if df.X*df.X+df.Y*df.Y+df.Z*df.Z<=r2 or dm.X*dm.X+dm.Y*dm.Y+dm.Z*dm.Z<=r2 then table.insert(out,it) end
    end
    return out
end

function _G.RC2Fn.runMachineGrabAlignSustainedPull(machineCenter,itemTuples,durationSec,keepAlign,tickSec,reuseAnchor,reuseAtt,softWoodPull)
    if not itemTuples or #itemTuples==0 then return nil end
    keepAlign=keepAlign==true
    local tw=(type(tickSec)=="number" and tickSec>0) and tickSec or 0.1
    local anchor,att
    local external=reuseAnchor and reuseAtt and reuseAnchor.Parent
    if external then
        anchor,att=reuseAnchor,reuseAtt
        pcall(function() anchor.CFrame=CFrame.new(machineCenter) end)
    else
        anchor,att=_G.RC2Fn.makeTempBH(machineCenter)
    end
    local t0=tick()
    while tick()-t0<durationSec and not _G.RC2Fn.mpShouldAbort() do
        if anchor and anchor.Parent then pcall(function() anchor.CFrame=CFrame.new(machineCenter) end) end
        for _,it in ipairs(itemTuples) do
            if it.model and it.model.Parent then
                _G.RC2Fn.refreshGrabTuplePart(it)
                if it.part and it.part.Parent then
        pcall(function() it.part.CanCollide=false end)
                    _G.RC2Fn.grabIntoBH(it.part,att,softWoodPull)
                end
            end
        end
        task.wait(tw)
    end
    if keepAlign then return anchor,att end
    for _,it in ipairs(itemTuples) do _G.RC2Fn.bhCleanupPartAndUngrab(it) end
    if not external then _G.RC2Fn.removeTempBH(anchor) end
    return nil
end

--- trackFedComplete=false：锯木机用，直到 Grab 里**再也 collect 不到**选中类型（不再用 fedComplete 标记跳过）
function _G.RC2Fn.mpMachineNetPollTeleportAndSuck(machineCenter,collectItems,pullDurationSec,uiTitle,emptyMsg,singlePassOnly,softWoodPull,trackFedComplete)
    local itemDest=machineCenter+Vector3.new(0,MP_MACHINE_TELEPORT_ABOVE_STUDS,0)
    _G.RC2Fn.mpSetProcessTeleportMarker(itemDest)
    local function clearm() _G.RC2Fn.mpClearProcessTeleportMarker() end
    if trackFedComplete==nil then trackFedComplete=true end
    local fedComplete={}
    local phase0=tick()
    local sawAny=false
    local pullSec=math.max(MP_MACHINE_PULL_MIN_SEC,pullDurationSec)
    local oneShot=singlePassOnly==true
    while not _G.RC2Fn.mpShouldAbort() do
        local raw=_G.RC2Fn.mpGrabTuplesValidOnly(collectItems())
        local items={}
        for _,it in ipairs(raw) do
            if trackFedComplete and fedComplete[it.model] then continue end
            table.insert(items,it)
        end
        if #items==0 then
            if #raw==0 then
                if sawAny then
                    _G.RC2Fn.mpNotify({Title=uiTitle,Content="加工完毕：Grab 内已无待处理物品",Duration=2.5,Icon="check"})
                else
                    _G.RC2Fn.mpNotify({Title=uiTitle,Content=emptyMsg or "没有物品",Duration=2,Icon="package"})
                end
            elseif trackFedComplete then
                _G.RC2Fn.mpNotify({Title=uiTitle,Content="Grab 内剩余物品均已投递过机器，视为加工完成",Duration=2.5,Icon="check"})
            end
            clearm()
            return
        end
        sawAny=true
        if tick()-phase0>MP_MACHINE_NET_PHASE_MAX_SEC then
            _G.RC2Fn.mpNotify({Title=uiTitle,Content=string.format("等待网络/加工超时(%ds)",MP_MACHINE_NET_PHASE_MAX_SEC),Duration=4,Icon="alert-circle"})
            clearm()
            return
        end
        for _,it in ipairs(items) do
            local pr=_G.RC2Fn.grabTeleportPartForModel(it.model) or _G.RC2Fn.grabInvokePartFor(it)
            if pr and pr.Parent then it.part=pr end
        end
        if _G.RC2Fn.mpShouldAbort() then _G.RC2Fn.mpNotify({Title=uiTitle,Content="已中断",Duration=2,Icon="alert-circle"}); clearm(); return end
        _G.RC2Fn.bhSendItemsToDest(items,itemDest,false,1)
        if _G.RC2Fn.mpShouldAbort() then _G.RC2Fn.mpNotify({Title=uiTitle,Content="已中断",Duration=2,Icon="alert-circle"}); clearm(); return end
        task.wait(0.03)
        if _G.RC2Fn.mpShouldAbort() then clearm(); return end
        _G.RC2Fn.runMachineGrabAlignSustainedPull(machineCenter,items,pullSec,false,nil,nil,nil,softWoodPull)
        if trackFedComplete then
            for _,it in ipairs(items) do fedComplete[it.model]=true end
        end
        if oneShot then
            _G.RC2Fn.mpNotify({Title=uiTitle,Content="本轮已抛光一次",Duration=2.5,Icon="check"})
            clearm()
            return
        end
        if _G.RC2Fn.mpShouldAbort() then _G.RC2Fn.mpNotify({Title=uiTitle,Content="已中断",Duration=2,Icon="alert-circle"}); clearm(); return end
        task.wait(0.03)
    end
end

