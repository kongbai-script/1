function _G.RC2Fn.refreshAnchorChamberCaches()
    local now=os.clock()
    if now-_acChamberTick<=5 and (_acZoneCache~=nil or #_acCollisionPartsCache>0 or _acBoxCf~=nil or _acChamberTick>0) then return end
    _acChamberTick=now
    _acZoneCache=nil
    _acCollisionPartsCache={}
    _acBoxCf=nil
    _acBoxSize=nil
        local home=_G.RC2Fn.findMyHome()
    if not home then
        if _acMirrorPart then _acMirrorPart.Parent=nil end
        return
    end
            local obj=home:FindFirstChild("Objects")
            local ac=obj and obj:FindFirstChild("Anchor Chamber")
    if not ac then
        if _acMirrorPart then _acMirrorPart.Parent=nil end
        return
    end
    if ac:IsA("Model") or ac:IsA("Folder") then
        for _,d in ipairs(ac:GetDescendants()) do
            if d:IsA("BasePart") and d.CanCollide and d.CanQuery then
                table.insert(_acCollisionPartsCache,d)
            end
        end
    end
    local zone=ac:FindFirstChild("Zone") or ac:FindFirstChildWhichIsA("BasePart")
            if zone and zone:IsA("BasePart") then _acZoneCache=zone end
    if ac:IsA("Model") then
        local ok,cf,sz=pcall(function() return ac:GetBoundingBox() end)
        if ok and cf and sz and sz.X>0.05 and sz.Y>0.05 and sz.Z>0.05 then
            _acBoxCf,_acBoxSize=cf,sz
        end
    elseif ac:IsA("Folder") then
        local plist={}
        for _,d in ipairs(ac:GetDescendants()) do
            if d:IsA("BasePart") then table.insert(plist,d) end
        end
        local cf,sz=_G.RC2Fn.acWorldAabbFromBaseParts(plist)
        if cf and sz then _acBoxCf,_acBoxSize=cf,sz end
    end
    if _acBoxCf and _acBoxSize then
        if not _acMirrorPart then
            _acMirrorPart=Instance.new("Part")
            _acMirrorPart.Name="AnchorChamberExclusionRegion"
            _acMirrorPart.Anchored=true
            _acMirrorPart.CanCollide=false
            _acMirrorPart.CanQuery=false
            _acMirrorPart.CanTouch=false
            _acMirrorPart.Transparency=1
        end
        _acMirrorPart.Size=_acBoxSize
        _acMirrorPart.CFrame=_acBoxCf
        _acMirrorPart.Parent=mpAnchorChamberFolder
    elseif _acMirrorPart then
        _acMirrorPart.Parent=nil
    end
end
function _G.RC2Fn.pointInAcChamberOBB(worldPos)
    if not _acBoxCf or not _acBoxSize then return false end
    local half=_acBoxSize*0.5
    local lp=_acBoxCf:PointToObjectSpace(worldPos)
    return math.abs(lp.X)<=half.X and math.abs(lp.Y)<=half.Y and math.abs(lp.Z)<=half.Z
end
function _G.RC2Fn.modelIntersectsAcChamberBox(m)
    if not m or not m.Parent or not _acBoxCf or not _acBoxSize then return false end
    local op=OverlapParams.new()
    op.FilterType=Enum.RaycastFilterType.Include
    op.FilterDescendantsInstances={m}
    op.RespectCanCollide=false
    local hits=workspace:GetPartBoundsInBox(_acBoxCf,_acBoxSize,op)
    return hits~=nil and #hits>0
end
function _G.RC2Fn.isInAnchorChamber(part)
    if not part or not part.Parent then return false end
    _G.RC2Fn.refreshAnchorChamberCaches()
    if not _acZoneCache then return false end
    local sz=_acZoneCache.Size/2
    local pos=_acZoneCache.CFrame:PointToObjectSpace(part.Position)
    return math.abs(pos.X)<=sz.X and math.abs(pos.Y)<=sz.Y and math.abs(pos.Z)<=sz.Z
end
function _G.RC2Fn.modelOverlapsAnchorChamberCollision(m)
    if not m or not m.Parent then return false end
    _G.RC2Fn.refreshAnchorChamberCaches()
    if #_acCollisionPartsCache==0 then return false end
    local ok,cf,size=pcall(function() return m:GetBoundingBox() end)
    if not ok or not cf then return false end
    local op=OverlapParams.new()
    op.FilterType=Enum.RaycastFilterType.Include
    op.FilterDescendantsInstances=_acCollisionPartsCache
    op.RespectCanCollide=true
    local hits=workspace:GetPartBoundsInBox(cf,size,op)
    return hits~=nil and #hits>0
end
function _G.RC2Fn.grabExcludedByAnchorChamber(model,part)
    if not model or not model.Parent then return true end
    _G.RC2Fn.refreshAnchorChamberCaches()
    if _acBoxCf and _acBoxSize then
        if part and part.Parent and _G.RC2Fn.pointInAcChamberOBB(part.Position) then return true end
        if _G.RC2Fn.modelIntersectsAcChamberBox(model) then return true end
    end
    if part and part.Parent and _G.RC2Fn.isInAnchorChamber(part) then return true end
    return _G.RC2Fn.modelOverlapsAnchorChamberCollision(model)
end
