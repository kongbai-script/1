function _G.RC2_MPXfer.batchTeleport(destPos,list,packAny,arriveStuds)
    if not list or #list==0 then return 0 end
    local lift=destPos+Vector3.new(0,3,0)
    if not packAny and not _G.RC2Fn.waitUntilAllGrabPrimariesNetworkLocal(list) then return 0 end
