--- 选中树 Model → Hittable 内世界 Y 最低的 Part → 底段 Charge；人物悬停在该段上方 freeze（仅砍树，不传送物品）
function _G.RC2Fn.runTreeChopBringBack(selKw,opts)
    opts=opts or {}
    local abortCheck=opts.abortCheck
    local nSeg=opts.heightSegments or 500
    local hoverAbove=opts.hoverAboveStuds or 2.5
    local delayAfter=opts.delayAfterCharge or 0.042
    local delaySwing=opts.delayBetweenSwings or 0.06
    local rounds=opts.roundsPerSwing or 2
    local atkA=selectedAlpha
    if type(atkA)=="number" and (atkA~=atkA or atkA==math.huge or atkA==-math.huge) then atkA=RC2_ATTACK_ALPHA_INF end
    local hrp0=_G.RC2Fn.getHRP()
    if not hrp0 then return false end
    local ws=workspace:FindFirstChild("WorldSpawn")
    local treesF=ws and ws:FindFirstChild("Trees")
    if not treesF then
        _G.RC2Fn.mpNotify({Title="树木",Content="没有 WorldSpawn.Trees",Duration=2,Icon="pickaxe"})
        return false
    end
    local targets=_G.RC2Fn.buildTreeMineTargets(treesF,selKw)
    if #targets==0 then
        _G.RC2Fn.mpNotify({Title="树木",Content="没有找到"..(selKw or "树"),Duration=2,Icon="pickaxe"})
        return false
    end
    local hrpSort=_G.RC2Fn.getHRP()
    if hrpSort then
        table.sort(targets,function(a,b)
            local pa=a.parts[1]; local pb=b.parts[1]
            if not pa or not pb then return false end
            return (pa.Position-hrpSort.Position).Magnitude<(pb.Position-hrpSort.Position).Magnitude
        end)
    end
    local data=targets[1]
    local model=data.model
    local partsNamed=_G.RC2Fn.collectHittablePartsNamedPart(model)
    if #partsNamed==0 then
        _G.RC2Fn.mpNotify({Title="树木",Content="该树 Hittable 内没有名为 Part 的部件",Duration=2,Icon="pickaxe"})
        return false
    end
    local rootPart=partsNamed[1]
    local bestY=_G.RC2Fn.partMinWorldY(rootPart)
    for i=2,#partsNamed do
        local py=_G.RC2Fn.partMinWorldY(partsNamed[i])
        if py<bestY then bestY=py; rootPart=partsNamed[i] end
    end
    if not rootPart or not rootPart.Parent then return false end
    local firstApproach=true
    while rootPart.Parent and model.Parent do
        if abortCheck and abortCheck() then break end
        local hp=_G.RC2Fn.hitPositionBottomSegment(rootPart,nSeg)
        if not hp then break end
        local hoverPos=hp+Vector3.new(0,hoverAbove,0)
        _G.RC2Fn.freezeAt(CFrame.new(hoverPos))
        if firstApproach then task.wait(0.35); firstApproach=false else task.wait(0.03) end
        if abortCheck and abortCheck() then break end
        hp=_G.RC2Fn.packHitPositionForCharge(hp)
        for _=1,rounds do
            if abortCheck and abortCheck() then break end
            if not rootPart.Parent then break end
            pcall(function() ChargeRemote:FireServer({Target=rootPart,HitPosition=hp}) end)
            pcall(function() AttackRemote:FireServer({Alpha=atkA,ResponseTime=0}) end)
            task.wait(delayAfter)
        end
        task.wait(delaySwing)
    end
    _G.RC2Fn.unfreeze()
    return true
end
