local function mpWorldPickBasePartFromInput(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton1 then
        local mse=player:GetMouse()
        local t=mse and mse.Target
        if t and t:IsA("BasePart") then return t end
        local cam=workspace.CurrentCamera
        if cam and mse then
            local ray=cam:ViewportPointToRay(mse.X,mse.Y)
            local rp=RaycastParams.new()
            rp.FilterType=Enum.RaycastFilterType.Exclude
            local ch=player.Character
            rp.FilterDescendantsInstances=ch and {ch} or {}
            local hit=workspace:Raycast(ray.Origin, ray.Direction * 2000, rp)
            if hit and hit.Instance and hit.Instance:IsA("BasePart") then return hit.Instance end
        end
        return nil
    end
    if inp.UserInputType==Enum.UserInputType.Touch then
        local cam=workspace.CurrentCamera
        if not cam then return nil end
        local p=inp.Position
        local ray=cam:ViewportPointToRay(p.X,p.Y)
        local rp=RaycastParams.new()
        rp.FilterType=Enum.RaycastFilterType.Exclude
        local ch=player.Character
        rp.FilterDescendantsInstances=ch and {ch} or {}
        local hit=workspace:Raycast(ray.Origin, ray.Direction * 2000, rp)
        if hit and hit.Instance and hit.Instance:IsA("BasePart") then return hit.Instance end
    end
    return nil
end
