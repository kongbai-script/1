function _G.RC2Fn.acWorldAabbFromBaseParts(parts)
    if not parts or #parts==0 then return nil,nil end
    local minV,maxV=nil,nil
    for _,bp in ipairs(parts) do
        if bp.Parent then
            local hs=bp.Size*0.5
            local cf=bp.CFrame
            for _,sx in ipairs({-1,1}) do
                for _,sy in ipairs({-1,1}) do
                    for _,sz in ipairs({-1,1}) do
                        local w=(cf*CFrame.new(sx*hs.X,sy*hs.Y,sz*hs.Z)).Position
                        if not minV then minV,maxV=w,w
                        else
                            minV=Vector3.new(math.min(minV.X,w.X),math.min(minV.Y,w.Y),math.min(minV.Z,w.Z))
                            maxV=Vector3.new(math.max(maxV.X,w.X),math.max(maxV.Y,w.Y),math.max(maxV.Z,w.Z))
                        end
                    end
                end
            end
        end
    end
    if not minV then return nil,nil end
    local center=(minV+maxV)*0.5
    local size=maxV-minV
    if size.X<0.05 or size.Y<0.05 or size.Z<0.05 then return nil,nil end
    return CFrame.new(center),size
end
local _acZoneCache=nil
local _acCollisionPartsCache={}
local _acChamberTick=0
local _acBoxCf=nil
local _acBoxSize=nil
local _acMirrorPart=nil
local mpAnchorChamberFolder=Instance.new("Folder")
mpAnchorChamberFolder.Name="MP_AnchorChamberRegions"
