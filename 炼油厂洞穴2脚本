function _G.RC2Fn.getPart(model)
    if not model or not model:IsA("Model") then return nil end
    local mp=model:FindFirstChild("MaterialPart")
    if mp and mp:IsA("BasePart") then return mp end
    for _,d in pairs(model:GetDescendants()) do
        if d:IsA("BasePart") and d.Name=="MaterialPart" then return d end
    end
    local wp=model:FindFirstChild("WoodPart")
    if wp and wp:IsA("BasePart") then return wp end
    for _,d in pairs(model:GetDescendants()) do
        if d.Name=="WoodPart" and d:IsA("BasePart") then return d end
    end
    local pp=model.PrimaryPart
    if pp and pp:IsA("BasePart") then return pp end
    for _,v in pairs(model:GetChildren()) do if v:IsA("BasePart") and not v.Anchored then return v end end
    return model:FindFirstChildWhichIsA("BasePart")
