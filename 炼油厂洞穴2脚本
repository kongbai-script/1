function _G.RC2Fn.partOwnerIsLocalForBH(part)
    if not part or not part:IsA("BasePart") then return false end
    if not _G.RC2Fn.partIsDescendantOfAnyGrabRoot(part) then return false end
    local inst=part
    while inst and inst~=workspace do
        if inst:IsA("Model") and _G.RC2Fn.grabTupleModelOwnerIsLocal(inst) then return true end
        inst=inst.Parent
    end
    return false
end
function _G.RC2Fn.poorBHReinforceExistingAligns()
    for p in pairs(poorBHParts) do
        if p and p.Parent then
            local al=p:FindFirstChild("MPBHAlign")
            if al and al:IsA("AlignPosition") then
                al.MaxVelocity=MPBH_MAX_VELO; al.Responsiveness=MPBH_RESP; al.MaxForce=1e9
            end
        else poorBHParts[p]=nil end
    end
end
function _G.RC2Fn.poorBHReleaseGrabbedOnly()
    for p in pairs(poorBHParts) do
        if p and p.Parent then
            pcall(function()
                local at=p:FindFirstChild("MPBHAtt"); if at then at:Destroy() end
                local al=p:FindFirstChild("MPBHAlign"); if al then al:Destroy() end
                p.AssemblyLinearVelocity=Vector3.zero; p.CanCollide=true
            end)
        end
    end
    poorBHParts={}
end
function _G.RC2Fn.poorBHHeartbeat()
    if not poorBHActive then return end
    local hrp=_G.RC2Fn.getHRP()
    if not hrp then return end
    local center=(hrp.CFrame*CFrame.new(0,0,-poorBHRadius*0.3)).Position
    poorBHAnchor.CFrame=CFrame.new(center)
    poorBHVis.CFrame=CFrame.new(center)
    poorBHVis.Transparency=1
    _G.RC2Fn.poorBHReinforceExistingAligns()
    local op=OverlapParams.new()
    op.FilterDescendantsInstances={player.Character or workspace,poorBHVis,poorBHAnchor,poorBHFolder,mpAlignFolder,mpAnchorChamberFolder}
    op.FilterType=Enum.RaycastFilterType.Exclude
    for _,p in ipairs(workspace:GetPartBoundsInRadius(hrp.Position,poorBHRadius,op)) do
        local par=p.Parent
        local isChar=par and (par:FindFirstChildOfClass("Humanoid") or (par.Parent and par.Parent:FindFirstChildOfClass("Humanoid")))
        if p:IsA("BasePart") and not p.Anchored and not isChar and not poorBHParts[p] then
            if poorBHSingleTargetSig then
                local m=_G.RC2Fn.poorBHGrabMaterialOrWoodModelFromPart(p)
                if not m or not _G.RC2Fn.modelIsInAnyGrabFolder(m) or not _G.RC2Fn.poorBHIdentityMatches(poorBHSingleTargetSig,m) then continue end
            end
            if not _G.RC2Fn.partOwnerIsLocalForBH(p) then continue end
            poorBHParts[p]=true
            _G.RC2Fn.grabIntoBH(p,poorBHAtt)
        end
    end
end
function _G.RC2Fn.poorBHEnsureConn()
    if poorBHConn then return end
    poorBHConn=RunService.Heartbeat:Connect(_G.RC2Fn.poorBHHeartbeat)
end
function _G.RC2Fn.poorBHDisable()
    poorBHActive=false
    if poorBHVis then poorBHVis.Transparency=1 end
    _G.RC2Fn.poorBHReleaseGrabbedOnly()
    if poorBHConn then poorBHConn:Disconnect(); poorBHConn=nil end
end

