        if _G.RC2Fn.isWood(d) then continue end
        local gmp=_G.RC2Fn.getMaterialPart(m)
        if gmp and d==gmp and (_G.RC2Fn.isOre(gmp) or _G.RC2Fn.isWood(gmp)) then continue end
