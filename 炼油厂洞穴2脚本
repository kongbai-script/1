function _G.RC2Fn.poorBHIdentityMatKey(v)
    if v==nil then return "" end
    local t=typeof(v)
    if t=="number" then return tostring(math.floor(v+0.5)) end
    if t=="boolean" then return v and "1" or "0" end
    local s=tostring(v)
    if s=="nil" then return "" end
    s=s:gsub("^%s+",""):gsub("%s+$","")
    return s
end
function _G.RC2Fn.poorBHBuildIdentitySignature(fromModel)
    if not fromModel or not fromModel:IsA("Model") then return nil end
    local n=fromModel.Name
    local mat=""
    if n=="MaterialPart" then
        local mp=_G.RC2Fn.getMaterialPart(fromModel)
        mat=_G.RC2Fn.poorBHIdentityMatKey((mp and mp:GetAttribute("Material")) or fromModel:GetAttribute("Material"))
    elseif n=="WoodPart" then
        local wp=_G.RC2Fn.getWoodPartModel(fromModel)
        mat=_G.RC2Fn.poorBHIdentityMatKey((wp and wp:GetAttribute("Material")) or fromModel:GetAttribute("Material"))
    else
        mat=_G.RC2Fn.poorBHIdentityMatKey(fromModel:GetAttribute("Material"))
    end
    return {name=n,mat=mat}
end
function _G.RC2Fn.poorBHIdentityMatches(sig,m)
    if not sig or not m or not m:IsA("Model") then return false end
    local s2=_G.RC2Fn.poorBHBuildIdentitySignature(m)
    if not s2 then return false end
    return sig.name==s2.name and _G.RC2Fn.poorBHIdentityMatKey(sig.mat)==s2.mat
end
function _G.RC2Fn.collectGrabTuplesForWoodIdentity(typeSig)
    local res={}
    if not typeSig then return res end
    for _,grabF in ipairs(_G.RC2Fn.getAllGrabRoots()) do
        _G.RC2Fn.forEachGrabOreOrWoodModel(grabF,function(v)
            if v.Name~="WoodPart" then return end
            if not _G.RC2Fn.poorBHIdentityMatches(typeSig,v) then return end
            if not _G.RC2Fn.modelOwnerIsLocalForGrabWood(v) then return end
            local strict=_G.RC2Fn.grabWoodBasePartStrict(v)
            local tp=_G.RC2Fn.grabTeleportPartForModel(v) or _G.RC2Fn.getWoodPartModel(v)
            if not tp or not tp.Parent then return end
            local part=(strict and strict.Parent and strict:IsDescendantOf(v)) and strict or tp
            if _G.RC2Fn.grabExcludedByAnchorChamber(v,part) then return end
            table.insert(res,{model=v,part=part})
        end)
    end
    _G.RC2Fn.sortGrabTuplesByDistance(res)
    return res
end
function _G.RC2Fn.poorBHGrabMaterialOrWoodModelFromPart(part)
    local inst=part
    while inst and inst~=workspace do
        if inst:IsA("Model") and _G.RC2Fn.modelIsInAnyGrabFolder(inst) then return inst end
        inst=inst.Parent
    end
    return nil
end

