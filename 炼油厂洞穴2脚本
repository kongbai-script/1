function _G.RC2Fn.getMaterialPart(model)
    if not model then return nil end
    local m=model:FindFirstChild("MaterialPart")
    if m and m:IsA("BasePart") then return m end
    for _,d in pairs(model:GetDescendants()) do
        if d:IsA("BasePart") and d.Name=="MaterialPart" then return d end
    end

    if model:IsA("Model") and model.Name=="MaterialPart" then
        local pp=model.PrimaryPart
        if pp and pp:IsA("BasePart") then return pp end
        local wp=_G.RC2Fn.getWoodPartModel(model)
        for _,d in pairs(model:GetDescendants()) do
            if not d:IsA("BasePart") then continue end
            if d.Name=="WoodPart" then continue end
            if wp and (d==wp or d:IsDescendantOf(wp)) then continue end
            return d
        end
    end
    return nil
end
