            local al=it.part:FindFirstChild("MPBHAlign"); if al then al:Destroy() end
            it.part.CanCollide=true; it.part.AssemblyLinearVelocity=Vector3.zero
        end)
    end
    if it.model and it.model.Parent then _G.RC2Fn.ungrabItem(_G.RC2Fn.getInvokeGrabPart(it.model,it.part)) end
end
local function _grabWoodModelDetectable(v,typeSig)
    if not v or v.Name~="WoodPart" or not _G.RC2Fn.modelOwnerIsLocalForGrabWood(v) then return false end
    if typeSig and not _G.RC2Fn.poorBHIdentityMatches(typeSig,v) then return false end
    local strict=_G.RC2Fn.grabWoodBasePartStrict(v)
    local tp=_G.RC2Fn.grabTeleportPartForModel(v)
    if typeSig then
        local part=(strict and strict.Parent and strict:IsDescendantOf(v)) and strict or tp
        if not part or not part.Parent then return false end
        if _G.RC2Fn.grabExcludedByAnchorChamber(v,part) then return false end
        return true
    end
    if strict and not _G.RC2Fn.grabExcludedByAnchorChamber(v,strict) then return true end
    if not tp or _G.RC2Fn.grabExcludedByAnchorChamber(v,tp) then return false end
    local mat=v:GetAttribute("Material") or ""
    if mat~="" and not _G.RC2Fn.isWoodMat(mat) then return false end
    return true
end
function _G.RC2Fn.grabWorkspaceHasWoodPart(typeSig)
    for _,g in ipairs(_G.RC2Fn.getAllGrabRoots()) do
        local found=false
        _G.RC2Fn.forEachGrabOreOrWoodModel(g,function(v)
            if found then return end
            if _grabWoodModelDetectable(v,typeSig) then found=true end
        end)
        if found then return true end
    end
    return false
end
function _G.RC2Fn.grabWorkspaceHasWoodPartExcluding(skipModels,typeSig)
    if not skipModels then return _G.RC2Fn.grabWorkspaceHasWoodPart(typeSig) end
    for _,g in ipairs(_G.RC2Fn.getAllGrabRoots()) do
        local found=false
        _G.RC2Fn.forEachGrabOreOrWoodModel(g,function(v)
            if found or skipModels[v] then return end
            if _grabWoodModelDetectable(v,typeSig) then found=true end
        end)
        if found then return true end
    end
    return false
end
function _G.RC2Fn.collectAllGrabWoodTuples(typeSig)
    local t={}
    for _,g in ipairs(_G.RC2Fn.getAllGrabRoots()) do
        _G.RC2Fn.forEachGrabOreOrWoodModel(g,function(v)
            if v.Name~="WoodPart" then return end
            if typeSig and not _G.RC2Fn.poorBHIdentityMatches(typeSig,v) then return end
            if not _G.RC2Fn.modelOwnerIsLocalForGrabWood(v) then return end
            local strict=_G.RC2Fn.grabWoodBasePartStrict(v)
            local tp=_G.RC2Fn.grabTeleportPartForModel(v)
            if not tp or not tp.Parent then return end
            local part=(strict and strict.Parent and strict:IsDescendantOf(v)) and strict or tp
            if typeSig then
                if _G.RC2Fn.grabExcludedByAnchorChamber(v,part) then return end
                table.insert(t,{model=v,part=part})
                return
            end
            if strict then
                if _G.RC2Fn.grabExcludedByAnchorChamber(v,part) then return end
                table.insert(t,{model=v,part=part})
                return
            end
            local mat=v:GetAttribute("Material") or ""
            if mat~="" and not _G.RC2Fn.isWoodMat(mat) then return end
            if _G.RC2Fn.grabExcludedByAnchorChamber(v,tp) then return end
            table.insert(t,{model=v,part=tp})
        end)
    end
    return t
end
function _G.RC2Fn.collectGrabTuplesForSifter()
    local res={}
    for _,grabF in ipairs(_G.RC2Fn.getAllGrabRoots()) do
        _G.RC2Fn.forEachGrabOreOrWoodModel(grabF,function(v)
            if v.Name~="MaterialPart" then return end
            if not _G.RC2Fn.modelOwnerIsLocal(v) then return end
            local strict=_G.RC2Fn.grabSmeltOreMaterialPartStrict(v)
            if not strict then return end
            local pick=_G.RC2Fn.grabTeleportPartForModel(v) or strict
            if _G.RC2Fn.grabExcludedByAnchorChamber(v,pick) then return end
            table.insert(res,{model=v,part=pick})
        end)
    end
    _G.RC2Fn.sortGrabTuplesByDistance(res)
    return res
end

function _G.RC2Fn.mpGrabTuplesValidOnly(items)
