        local mat=tostring(mp:GetAttribute("Material") or "")
        if mat~="" and (mat==ks or mat:lower():find(ks:lower(),1,true)) then return true end
    end
    local p=m.Parent
    if p and p:IsA("Folder") then
        local pn=p.Name
        if pn~="" and pn~="Ores" and pn~="WorldSpawn" then
            if pn==ks or pn:lower():find(ks:lower(),1,true) then return true end
