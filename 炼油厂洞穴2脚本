function _G.RC2Fn.processPackager(packager, itemsList)
    if not packager then return end
    _G.RC2Fn.mpClearAbort()
    local grabs=_G.RC2Fn.mpRescanGrabRoots()
    if #grabs==0 then _G.RC2Fn.mpNotify({Title="打包机",Content="全图未找到 Grab",Duration=3,Icon="alert-circle"}); return end
    local pPos=packager:GetPivot().Position
    local itemDest=pPos+Vector3.new(0,MP_MACHINE_TELEPORT_ABOVE_STUDS,0)
    if #itemsList==0 then _G.RC2Fn.mpNotify({Title="打包机",Content="没有物品",Duration=2,Icon="package"}); return end
    local items={}
    for _,t in ipairs(itemsList) do
        local m=t and t.model
        if m and m.Parent and _G.RC2Fn.modelOwnerIsLocal(m) then
            local pt=t.part
            if not pt or not pt.Parent or not pt:IsDescendantOf(m) then pt=nil end
            pt=_G.RC2Fn.grabTeleportPartForModel(m,pt)
            if pt then table.insert(items,{model=m,part=pt}) end
        end
    end
    if #items==0 then _G.RC2Fn.mpNotify({Title="打包机",Content="选中项没有零件",Duration=2,Icon="package"}); return end
    _G.RC2Fn.mpSetProcessTeleportMarker(itemDest)
    local function doneM() _G.RC2Fn.mpClearProcessTeleportMarker() end
    local moved=_G.RC2Fn.bhSendItemsToDest(items,itemDest,false,1,false)
    if _G.RC2Fn.mpShouldAbort() then doneM(); _G.RC2Fn.mpNotify({Title="打包机",Content="已中断",Duration=2,Icon="alert-circle"}); return end
    task.wait(0.08)
    if _G.RC2Fn.mpShouldAbort() then doneM(); return end
    local grabbed=_G.RC2Fn.tuplesNearPosition(items,itemDest,48)
    if #grabbed==0 then grabbed=items end
    local anchor=_G.RC2Fn.runMachineGrabAlignSustainedPull(pPos,grabbed,3.2,true)
    if _G.RC2Fn.mpShouldAbort() then if anchor then _G.RC2Fn.removeTempBH(anchor) end; _G.RC2Fn.setNoClip(false); doneM(); _G.RC2Fn.mpNotify({Title="打包机",Content="已中断",Duration=2,Icon="alert-circle"}); return end
    _G.RC2Fn.setNoClip(true)
    task.wait(0.08)
    if _G.RC2Fn.mpShouldAbort() then
        for _,it in ipairs(grabbed) do _G.RC2Fn.bhCleanupPartAndUngrab(it) end
        if anchor then _G.RC2Fn.removeTempBH(anchor) end
        _G.RC2Fn.setNoClip(false)
        doneM()
        _G.RC2Fn.mpNotify({Title="打包机",Content="已中断",Duration=2,Icon="alert-circle"})
        return
    end
    _G.RC2Fn.firePackagerPanelInteract(packager)
    task.wait(0.6)
    if _G.RC2Fn.mpShouldAbort() then
        for _,it in ipairs(grabbed) do _G.RC2Fn.bhCleanupPartAndUngrab(it) end
        if anchor then _G.RC2Fn.removeTempBH(anchor) end
        _G.RC2Fn.setNoClip(false)
        doneM()
        _G.RC2Fn.mpNotify({Title="打包机",Content="已中断",Duration=2,Icon="alert-circle"})
        return
    end
    for _,it in ipairs(grabbed) do
        pcall(function()
            local a2=it.part:FindFirstChild("MPBHAtt"); if a2 then a2:Destroy() end
            local al=it.part:FindFirstChild("MPBHAlign"); if al then al:Destroy() end
            it.part.CanCollide=true; it.part.AssemblyLinearVelocity=Vector3.zero
        end)
        _G.RC2Fn.ungrabItem(_G.RC2Fn.getInvokeGrabPart(it.model,it.part))
    end
    if anchor then _G.RC2Fn.removeTempBH(anchor) end
    _G.RC2Fn.setNoClip(false)
    doneM()
    _G.RC2Fn.mpNotify({Title="打包",Content="完成 x"..moved,Duration=2,Icon="check"})
end

