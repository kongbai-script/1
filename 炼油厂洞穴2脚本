local function MP_AirflowMkWindow(opts)
    opts=opts or {}
    local decoyKb=Enum.KeyCode.F15
    local raw=MP_Airflow:Init({
        Name=opts.Title or "Moon Pixel",
        Keybind=decoyKb,
        Logo="http://www.roblox.com/asset/?id=118752982916680",
        Resizable=opts.Resizable==true,
    })
    pcall(function() raw:SetKeybind(decoyKb) end)
    pcall(function() if opts.Resizable and raw.SetResizable then raw:SetResizable(true) end end)
    local TweenService=game:GetService("TweenService")
    local shell={busy=false,openSize=nil,openPos=nil,lastSmall=nil}
    local function mpAirflowShellToggle()
        if shell.busy then return end
        local UIS=game:GetService("UserInputService")
        if UIS:GetFocusedTextBox()~=nil then return end
        local g=MP_findAirflowWindowGui()
        if not g then return end
        local wf=MP_findAirflowWindowFrameInScreenGui(g)
        if not wf then
            g.Enabled=not g.Enabled
            return
        end
        local tiClose=TweenInfo.new(0.38,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
        local tiOpen=TweenInfo.new(0.4,Enum.EasingStyle.Quint,Enum.EasingDirection.Out)
        local function smallFrom(w)
            local ax=math.max(1,w.AbsoluteSize.X)
            local ay=math.max(1,w.AbsoluteSize.Y)
            return UDim2.fromOffset(math.clamp(math.floor(ax*0.14),68,130),math.clamp(math.floor(ay*0.14),52,100))
        end
        if g.Enabled and wf.BackgroundTransparency<0.92 then
            shell.busy=true
            shell.openSize=wf.Size
            shell.openPos=wf.Position
            shell.lastSmall=smallFrom(wf)
            local tw=TweenService:Create(wf,tiClose,{Size=shell.lastSmall,BackgroundTransparency=1})
            tw:Play()
            pcall(function() tw.Completed:Wait() end)
            task.wait(0.05)
            if g.Parent then g.Enabled=false end
            shell.busy=false
        else
            shell.busy=true
            g.Enabled=true
            task.wait()
            wf=MP_findAirflowWindowFrameInScreenGui(g) or wf
            local tgtS,tgtP=shell.openSize,shell.openPos
            if not tgtS then
                tgtS,tgtP=wf.Size,wf.Position
                shell.openSize,shell.openPos=tgtS,tgtP
            end
            local startSm=shell.lastSmall or smallFrom(wf)
            wf.BackgroundTransparency=1
            wf.Size=startSm
            if tgtP then wf.Position=tgtP end
            local tw2=TweenService:Create(wf,tiOpen,{Size=tgtS,BackgroundTransparency=0.6,Position=tgtP or wf.Position})
            tw2:Play()
            pcall(function() tw2.Completed:Wait() end)
            shell.busy=false
        end
    end
    if _G.RC2Fn then _G.RC2Fn.mpAirflowShellToggle=mpAirflowShellToggle end
    if not MP_airflowShellGHooked then
        MP_airflowShellGHooked=true
        game:GetService("UserInputService").InputBegan:Connect(function(input,gameProcessed)
            if gameProcessed or input.KeyCode~=Enum.KeyCode.G then return end
            local fn=_G.RC2Fn and _G.RC2Fn.mpAirflowShellToggle
            if fn then fn() end
        end)
    end
    local secByTab={}
    local function sectionFor(airTab)
        if not secByTab[airTab] then
            secByTab[airTab]=airTab:AddSection({Name=" ",Position="left"})
        end
        return secByTab[airTab]
    end
    local function tabShim(spec)
        local airTab=raw:DrawTab({
            Name=(spec and spec.Title) or "Tab",
            Icon=MP_airflowTabIcon(spec and spec.Icon),
        })
        local S=sectionFor(airTab)
        local out={}
        function out:Button(o)
            local cb=o.Callback or function()end
            S:AddButton({Name=o.Title,Callback=function() cb() end})
        end
        function out:Toggle(o)
            local cb=o.Callback or function()end
            local api=S:AddToggle({Name=o.Title,Default=o.Value or false,Callback=cb})
            return {
                Set=function(_,v) pcall(function() api:SetValue(v) end) end,
                SetValue=function(_,v) pcall(function() api:SetValue(v) end) end,
            }
        end
        function out:Slider(o)
            local v=o.Value or {Min=0,Max=100,Default=0}
            local step=o.Step or 1
            local rnd=0
            if step<=0.01 then rnd=2 elseif step<=0.1 then rnd=1 end
            S:AddSlider({
                Name=o.Title,
                Min=v.Min,Max=v.Max,Default=v.Default,
                Round=rnd,
                Callback=o.Callback or function()end,
            })
        end
        function out:Dropdown(o)
            local vals=o.Values or {}
            local multi=o.Multi==true
            local defStr=tostring(o.Value or vals[1] or "")
            local cb=o.Callback or function()end
            local dd=S:AddDropdown({
                Name=o.Title,
                Values=vals,
                Default=defStr,
                Multi=multi,
                Callback=cb,
            })
            return {
                Refresh=function(_,arr)
                    pcall(function() dd:SetValues(arr) end)
                end,
                Select=function(_,name)
                    pcall(function() dd:SetDefault(name) end)
                end,
            }
        end
        function out:Divider()
            S:AddParagraph({Name=" ",Content=" "})
        end
        function out:Space() end
        return out
    end
    return {
        Tab=function(_,spec) return tabShim(spec) end,
        Toggle=function() mpAirflowShellToggle() end,
    }
end

