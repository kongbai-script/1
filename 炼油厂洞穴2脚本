function _G.RC2Fn.isFish(v)
    if v:IsA("Model") then return _G.RC2Fn.grabModelIsFishCatch(v) end
    if not v:IsA("BasePart") then return false end
    if v.Name=="MaterialPart" or v.Name=="WoodPart" then return false end
    if _G.RC2Fn.isWood(v) then return false end
    local m=v:FindFirstAncestorOfClass("Model")
    if not m then return false end
    local inGrab=false
    for _,gf in ipairs(_G.RC2Fn.getAllGrabRoots()) do if m:IsDescendantOf(gf) then inGrab=true break end end
    if not inGrab then return false end
    if not _G.RC2Fn.grabModelIsFishCatch(m) then return false end
    local mp=_G.RC2Fn.getMaterialPart(m)
    if mp and _G.RC2Fn.isOre(mp) and (v==mp or v:IsDescendantOf(mp)) then return false end
    local wp=_G.RC2Fn.getWoodPartModel(m)
    if wp and (v==wp or v:IsDescendantOf(wp)) then return false end
    return true
end

local POLISHABLE_MATERIAL_KEYS={
    "Weeping Soul","Pink Diamond","Sphalerite","Abyssalite","Deepslate","Wildcore","Limestone",
    "Crimsone","Obsidian","Chocolate","Diamond","Emerald","Sapphire","Cobalt","Lithium",
    "Topaz","Ruby","Noir","Gold","Iron","Sand","Stone",
}
table.sort(POLISHABLE_MATERIAL_KEYS,function(a,b) return #a>#b end)
local function rc2NormPolishMatAttrib(s)
    if type(s)~="string" or s=="" then return "" end
    s=string.lower(s)
    s=s:gsub("[-_]"," "):gsub("^%s+",""):gsub("%s+$",""):gsub("%s+"," ")
    while true do
        local t=s:gsub("^raw%s*",""):gsub("^refined%s*",""):gsub("^molten%s*","")
        if t==s then break end
        s=t:gsub("%s+"," "):gsub("^%s+",""):gsub("%s+$","")
    end
    return s
end
local function rc2MatNormContainsPolishKey(n,kn)
    if n==kn then return true end
    local i,j=string.find(n,kn,1,true)
    if not i then return false end
    if i>1 then
        local prev=string.byte(n,i-1)
        if prev>=string.byte("a") and prev<=string.byte("z") then return false end
    end
    if j<#n then
        local nx=string.byte(n,j+1)
        if nx>=string.byte("a") and nx<=string.byte("z") then return false end
    end
    return true
end
function _G.RC2Fn.isPolishableMaterialPart(mp,model)
    if not mp or not mp:IsA("BasePart") then return false end
    if mp.Name~="MaterialPart" and not (model and model:IsA("Model") and model.Name=="MaterialPart") then return false end
    local mat=mp:GetAttribute("Material") or (model and model:GetAttribute("Material")) or ""
    if mat=="" or _G.RC2Fn.isWoodMat(mat) then return false end
    local n=rc2NormPolishMatAttrib(mat)
    if n=="" then return false end
    for _,key in ipairs(POLISHABLE_MATERIAL_KEYS) do
        if rc2MatNormContainsPolishKey(n,string.lower(key)) then return true end
    end
    return false
end

function _G.RC2Fn.grabOwnerValueMatchesLocalPlayer(m)
    if not m or not m:IsA("Model") then return false end
    local ow=m:FindFirstChild("Owner")
    if not ow then return false end
    local ok,v=pcall(function() return ow.Value end)
    if not ok or v==nil then return false end
    if v==player then return true end
    if typeof(v)=="Instance" then
        if v:IsA("Player") then return v==player end
        return false
    end
    if typeof(v)=="number" then
        local n=tonumber(v)
        return n~=nil and math.floor(n)==player.UserId
    end
    if typeof(v)=="string" then
        return v==player.Name or v==tostring(player.UserId)
    end
